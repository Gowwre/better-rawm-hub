=\"background-color: transparent;text-align: center;height: 45px;\">\r\n    <button name=\"recorded-mapping-key\" style=\"margin: 10px 10px 10px 10px;background-color: transparent;border-color: transparent;\"></button>\r\n  </div>\r\n</div>\r\n\r\n<div id=\"setting-mapping-macro-edit-panel\" class=\"layui-form\" style=\"display: none;width: 568px;height: 318px;\">\r\n  <div id=\"mapping-macro-edit-container\">\r\n  </div>\r\n</div>\r\n\r\n<div id=\"setting-mapping-macro-add-panel\" class=\"layui-form mapping-macro-add-panel\" style=\"display: none; margin-left:16px; margin-right:16px; min-width: 400px;min-height: 220px;\">\r\n  <div class=\"layui-setting-title-container\" style=\"margin-top: 10px;\">\r\n    <p class=\"layui-setting-title\" data-i18n-text=\"STRID_SETTING_MAPPING_SELECT_KEY\">选择按键</p>\r\n    <div id=\"mapping-macro-add-select-key\" class=\"layui-input-inline\" style=\"width: 200px;margin-left: 10px;\"></div>\r\n    <button id=\"kbd-macro-add-select-key\" class=\"layui-btn layui-key-desc-button\" style=\"width: 120px; margin-left: 10px; border: 1px solid gray\" kbd-macro-add-select-key-action=\"select\" data-i18n-text=\"STRID_NONE\">无</button>\r\n  </div>\r\n  <div id=\"macro-add-select-key-container\" class=\"layui-setting-title-container\" style=\"margin-top: 16px;\">\r\n    <p class=\"layui-setting-title\" style=\"width:100px;\" data-i18n-text=\"STRID_SETTING_MAPPING_MACRO_ACTION_SELECT\">选择动作</p>\r\n    <div class=\"layui-form-item layui-row\" style=\"width:100%;margin-bottom: 0px;\">\r\n      <div class=\"layui-col-xs4\">\r\n        <input type=\"radio\" name=\"mapping-macro-action-key-event\" style=\"width: 50%;\" value=\"0\" title=\"按下\" data-i18n-title=\"STRID_SETTING_MAPPING_MACRO_ACTION_KEY_DOWN\" lay-filter=mapping-macro-action-key-event\">\r\n      </div>\r\n      <div class=\"layui-col-xs4\">\r\n        <input type=\"radio\" name=\"mapping-macro-action-key-event\"  style=\"width: 50%;\" value=\"1\" title=\"松开\" data-i18n-title=\"STRID_SETTING_MAPPING_MACRO_ACTION_KEY_UP\" lay-filter=\"mapping-macro-action-key-event\">\r\n      </div>\r\n    </div>\r\n  </div>\r\n  <div id=\"macro-add-wheel-delta-container\" class=\"layui-setting-title-container\" style=\"margin-top: 16px; display: none;\">\r\n    <p class=\"layui-setting-title\" data-i18n-text=\"STRID_SETTING_MAPPING_MACRO_ACTION_WHEEL_DELTA\">滚动步长</p>\r\n    <input id=\"macro-add-wheel-delta-input\" class=\"layui-input\" type=\"number\" lay-affix=\"number\" lay-filter=\"macro-add-wheel-delta-input\" style=\"width: 200px;margin-left: 10px; display: block;\" placeholder=\"\" step=\"1\" min=\"0\">\r\n  </div>\r\n  <div id=\"macro-add-move-delta-container\" class=\"layui-setting-title-container\" style=\"margin-top: 16px; display: none;\">\r\n    <p class=\"layui-setting-title\" data-i18n-text=\"STRID_SETTING_MAPPING_MACRO_ACTION_MOVE_DELTA\">移动步长</p>\r\n    <p class=\"layui-setting-title\" style=\"margin-left: 10px;\">X</p>\r\n    <input id=\"macro-add-move-delta-x-input\" class=\"layui-input\" type=\"number\" lay-affix=\"number\" lay-filter=\"macro-add-move-delta-x-input\" style=\"width: 80px;margin-left: 5px; display: block;\" placeholder=\"\" step=\"0.1\" min=\"0\">\r\n    <p class=\"layui-setting-title\" style=\"margin-left: 10px;\">Y</p>\r\n    <input id=\"macro-add-move-delta-y-input\" class=\"layui-input\" type=\"number\" lay-affix=\"number\" lay-filter=\"macro-add-move-delta-y-input\" style=\"width: 80px;margin-left: 5px; display: block;\" placeholder=\"\" step=\"0.1\" min=\"0\">\r\n    <p class=\"layui-setting-title\" style=\"margin-left: 10px;\" data-i18n-text=\"STRID_SETTING_LIGHT_LOOP\">循环</p>\r\n    <input id=\"macro-add-move-loop-input\" class=\"layui-input\" type=\"number\" lay-affix=\"number\" lay-filter=\"macro-add-move-loop-input\" style=\"width: 80px;margin-left: 5px; display: block;\" placeholder=\"\" step=\"1\" min=\"1\">\r\n  </div>\r\n  <div id=\"macro-add-position-container\" class=\"layui-setting-title-container\" style=\"margin-top: 16px; display: none;\">\r\n    <p class=\"layui-setting-title\" data-i18n-text=\"STRID_SETTING_MAPPING_MACRO_ACTION_POSITION\">定位坐标</p>\r\n    <p class=\"layui-setting-title\" style=\"margin-left: 10px;\">X</p>\r\n    <input id=\"macro-add-position-x-input\" class=\"layui-input\" type=\"number\" lay-affix=\"number\" lay-filter=\"macro-add-position-x-input\" style=\"width: 80px;margin-left: 5px; display: block;\" placeholder=\"\" step=\"1\" min=\"0\">\r\n    <p class=\"layui-setting-title\" style=\"margin-left: 10px;\">Y</p>\r\n    <input id=\"macro-add-position-y-input\" class=\"layui-input\" type=\"number\" lay-affix=\"number\" lay-filter=\"macro-add-position-y-input\" style=\"width: 80px;margin-left: 5px; display: block;\" placeholder=\"\" step=\"1\" min=\"0\">\r\n  </div>\r\n  <div class=\"layui-setting-title-container\" style=\"margin-top: 16px;\">\r\n    <p class=\"layui-setting-title\" data-i18n-text=\"STRID_SETTING_MAPPING_MACRO_ACTION_KEEP_TIME\">持续时间</p>\r\n    <button id=\"mapping-macro-more-keep-time\" class=\"layui-btn layui-btn-radius layui-btn-sm\" style=\"margin-left: 10px;background-color: #16B777;\" mapping-macro-more-keep-time-action=\"edit\" data-i18n-text=\"STRID_SETTING_MAPPING_MACRO_ACTION_MORE_KEEP_TIME\">更长时间</button>\r\n    <button id=\"mapping-macro-less-keep-time\" class=\"layui-btn layui-btn-radius layui-btn-sm\" style=\"margin-left: 20px;background-color: #16B777;\" mapping-macro-less-keep-time-action=\"edit\" data-i18n-text=\"STRID_SETTING_MAPPING_MACRO_ACTION_LESS_KEEP_TIME\">更短时间</button>\r\n  </div>\r\n  <table style=\"margin-left:10px;margin-top:50px;\">\r\n    <tr>\r\n      <td>\r\n        <div id=\"slider-mapping-macro-keep-time-input\" style=\"width:380px;\"></div>\r\n      </td>\r\n      <td>\r\n        <p data-i18n-text=\"STRID_SETTING_UNIT_MS\" style=\"margin-left: 5px;\">毫秒</p>\r\n      </td>\r\n    </tr>\r\n  </table>\r\n</div>\r\n\r\n<div id=\"select-key-panel\" class=\"layui-form \" style=\"display: none; margin-left:16px; margin-right:16px; min-width: 1030px;min-height: 340px;\">\r\n  <div id=\"dialog-select-key-container\" style=\"width: 100%;height: 290px\">\r\n  </div>\r\n  <div class=\"layui-setting-title-container\">\r\n    <div class=\"layui-setting-title-bar\" style=\"margin-right: 4px;\"></div>\r\n    <p data-i18n-text=\"STRID_KBD_MOUSE_KEY\">鼠标按键</p>\r\n  </div>\r\n  <div id=\"dialog-mouse-select-key-container\" style=\"width: 100%;height: 40px\">\r\n  </div>\r\n</div>\r\n\r\n<div id=\"setting-mapping-macro-record-panel\" class=\"layui-form\" style=\"display: none;margin: 16px; min-width: 400px;\">\r\n  <p id=\"macro-record-waiting-info\" class=\"layui-setting-desc\" data-i18n-text=\"STRID_SETTING_MAPPING_MACRO_RECORD_WAITING_EX\" style=\"display: none;\"></p>\r\n  <div id=\"macro-record-fixed-time-container\" style=\"margin-top: 20px;\">\r\n    <input type=\"checkbox\" name=\"macro-record-fixed-time\" value=\"1\" title=\"\" lay-filter=\"macro-record-fixed-time\" data-i18n-title=\"STRID_SETTING_MAPPING_MACRO_RECORD_FIXED_TIME\" checked>\r\n  </div>\r\n</div>\r\n\r\n<div id=\"factory-reset-panel\" class=\"layui-form\" style=\"display: none;margin: 16px; width: 400px;\">\r\n  <p class=\"layui-setting-desc\" data-i18n-text=\"STRID_SETTING_FACTORY_RESET_WARNING\">此操作将彻底删除鼠标内所有的配置数据，将其恢复至出厂状态，且无法撤销，确定吗？</p>\r\n  <div style=\"margin-top: 20px;\">\r\n    <input type=\"checkbox\" name=\"factory-reset-esb\" value=\"1\" title=\"\" lay-filter=\"factory-reset-esb\" data-i18n-title=\"STRID_SETTING_FACTORY_RESET_ESB\">\r\n  </div>\r\n</div>\r\n\r\n<div id=\"wireless-optimize-panel\" class=\"layui-form\" style=\"display: none;margin: 16px; width: 400px;\">\r\n  <p class=\"layui-setting-desc\" data-i18n-text=\"STRID_SETTING_FACTORY_TEST_INFO\"></p>\r\n  <table style=\"width: 100%;\">\r\n    <tr>\r\n      <td style=\"text-align: center;font-size: large;\">\r\n        <p id=\"wireless-optimize-busy\"></p>\r\n      </td>\r\n    </tr>\r\n  </table>\r\n</div>\r\n\r\n<div id=\"receiver-light-setting-panel\" class=\"layui-form\" style=\"display: none;margin: 16px; width: 400px;\">\r\n  <p class=\"layui-setting-desc\" data-i18n-text=\"STRID_RECEIVER_SETTING_LIGHT_MODE_DESC\">选择接收器上的灯效所传达的信息</p>\r\n  <div class=\"layui-form\" style=\"margin-top: 20px;\">\r\n    <input type=\"radio\" name=\"receiver-light-mode\" lay-filter=\"receiver-light-mode\" value=\"0\" title=\"连接状态\" data-i18n-title=\"STRID_RECEIVER_SETTING_LIGHT_MODE_CONNECT\">\r\n    <p style=\"margin-left: 30px;\" data-i18n-text=\"STRID_RECEIVER_SETTING_LIGHT_MODE_CONNECT_DESC\">只有当鼠标连接到接收器时才会点亮并保持白色常亮</p>\r\n    <input type=\"radio\" name=\"receiver-light-mode\" lay-filter=\"receiver-light-mode\" value=\"1\" title=\"电池状态\" data-i18n-title=\"STRID_RECEIVER_SETTING_LIGHT_MODE_BATTERY\" checked> \r\n    <p style=\"margin-left: 30px;\" data-i18n-text=\"STRID_RECEIVER_SETTING_LIGHT_MODE_BATTERY_DESC\">根据鼠标当前的电池电量，从绿色（大于40%）、黄色（大于30%）、红色（小于30%）逐渐变化</p>\r\n    <input type=\"radio\" name=\"receiver-light-mode\" lay-filter=\"receiver-light-mode\" value=\"2\" title=\"仅电量警告\" data-i18n-title=\"STRID_RECEIVER_SETTING_LIGHT_MODE_BATTERY_WARNING\"> \r\n    <p style=\"margin-left: 30px;\" data-i18n-text=\"STRID_RECEIVER_SETTING_LIGHT_MODE_BATTERY_WARNING_DESC\">始终保持熄灭，尽在鼠标需要充电时闪烁红色</p>\r\n  </div>\r\n</div>\r\n\r\n<div id=\"key-delay-guide-panel\" class=\"layui-form\" style=\"display: none;\">\r\n  <img id=\"key-delay-guide-img\" src=\"\" width=\"auto\" height=\"500px\">\r\n</div>\r\n\r\n<div id=\"kbd-key-waiting-panel\" class=\"full-screen\" style=\"display: none;\">\r\n  <i id=\"onboard-config-loading\" class=\"layui-icon layui-icon-loading layui-anim layui-anim-rotate layui-anim-loop\" style=\"font-size: 20px; color: #1E9FFF;margin-left: 5px;\"></i>\r\n  <p style=\"margin-left: 20px;\" data-i18n-text=\"STRID_KBD_WAITING\">正在处理，请耐心等待</p>\r\n</div>\r\n\r\n<div id=\"kbd-factory-reset-panel\" class=\"layui-form\" style=\"display: none;margin: 16px; width: 400px;\">\r\n  <p class=\"layui-setting-desc\" data-i18n-text=\"STRID_KBD_FACTORY_RESET_WARNING\">此操作将彻底删除键盘内所有的配置数据，包括键盘按键，磁轴设置，灯效设置等，将其恢复至出厂状态，且无法撤销，确定吗？</p>\r\n</div>\r\n\r\n<div id=\"kbd-keycode-factory-reset-panel\" class=\"layui-form\" style=\"display: none;margin: 16px; width: 400px;\">\r\n  <p class=\"layui-setting-desc\" data-i18n-text=\"STRID_KBD_KEYCODE_FACTORY_RESET_WARNING\">此操作将彻底删除键盘按键配置数据，将其恢复至出厂状态，且无法撤销，确定吗？</p>\r\n</div>\r\n\r\n<div class=\"footer layui-auto-zoom\">\r\n  <p><a href=\"https://www.rawmtech.com/\" target=\"_blank\">©2019 深圳市仁魔电子科技有限公司</a> 版权所有 &nbsp;&nbsp;&nbsp;<a href=\"https://beian.miit.gov.cn/\" target=\"_blank\">粤ICP备19106751号</a></p>\r\n</div>\r\n\r\n<script type=\"text/javascript\" src=\"https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js\"></script>\r\n<script type=\"text/javascript\" src=\"https://cdnjs.cloudflare.com/ajax/libs/layui/2.9.18/layui.min.js\"></script>\r\n<script type=\"text/javascript\" src=\"https://cdnjs.cloudflare.com/ajax/libs/sprintf/1.1.3/sprintf.min.js\"></script>\r\n<script type=\"text/javascript\" src=\"https://cdnjs.cloudflare.com/ajax/libs/bignumber.js/9.1.2/bignumber.min.js\"></script>\r\n<script type=\"text/javascript\" src=\"https://cdnjs.cloudflare.com/ajax/libs/platform/1.3.6/platform.min.js\"></script>\r\n<script type=\"text/javascript\" src=\"https://cdnjs.cloudflare.com/ajax/libs/spectrum/1.8.1/spectrum.min.js\"></script>\r\n<script type=\"text/javascript\" src=\"https://hub.miracletek.net/hub/js/library.min.js?v=202604030024\"></script>\r\n</body>\r\n</html>\r\n"
