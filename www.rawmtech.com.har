i-bg-blue layui-btn-lg\" style=\"margin-top: 40px;\" kbd-keycode-factory-reset-action=\"apply\" data-i18n-text=\"STRID_KBD_KEYCODE_FACTORY_RESET\">重置键盘按键</button>\r\n              <button id=\"kbd-factory-reset\" class=\"layui-btn layui-btn-radius layui-bg-blue layui-btn-lg\" style=\"margin-left: 20px; margin-top: 40px;\" kbd-factory-reset-action=\"apply\" data-i18n-text=\"STRID_SETTING_FACTORY_RESET\">恢复出厂设置</button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div class=\"layui-tab-item layui-show\">\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</div>\r\n\r\n<div id=\"pair-panel\" style=\"display: none;background-color: transparent;text-align: center;margin-bottom: 20px;\">\r\n  <button id=\"pair-rawm-slogan\" style=\"font-size: 60px;margin-top: 20px;background-color: transparent;border-color: transparent;\" data-i18n-text=\"STRID_WEBHUB_RAWM_SLOGAN\">欢迎使用RAWM HUB WEB</button>\r\n  <br>\r\n  <button id=\"pair-hub-desc\" style=\"font-size: 20px;margin-bottom: 150px;background-color: transparent;border-color: transparent;\" data-i18n-text=\"STRID_WEBHUB_RAWM_HUB_DESC\">兼容Windows、Mac、Linux操作系统基于Chromium的浏览器，如Chrome、Edge</button>\r\n  <br>\r\n  <button id=\"pair-hub-detail\" style=\"display: none; font-size: 20px;margin-bottom: 15px;background-color: transparent;border-color: transparent;margin-bottom: 80px;\" data-i18n-text=\"STRID_WEBHUB_RAWM_HUB_DETAIL\">在驱动中可以根据您的习惯去调节DPI、回报率，自定义宏按键与编程等一系列配置，更多功能期待您的探索。</button>\r\n  <br>\r\n  <button id=\"pair-device\" class=\"layui-btn layui-btn-radius layui-bg-blue layui-btn-lg\" pair-action=\"pair\" data-i18n-text=\"STRID_WEBHUB_CONNECT_DEVICE\">连接您的设备</button>\r\n  <i id=\"pairing-waiting\" class=\"layui-icon layui-icon-loading layui-anim layui-anim-rotate layui-anim-loop\" style=\"font-size: 36px;display: none;\"></i>\r\n  <br>\r\n  <button id=\"pairing-tips\" style=\"font-size: larger;background-color: transparent;border-color: transparent;display: none;\" data-i18n-text=\"STRID_WEBHUB_CONNECT_TIPS\">请在浏览器地址栏旁边打开的设备列表中选择您的设备，然后单击“连接”。</button>\r\n</div>\r\n\r\n<div id=\"connect-panel\" style=\"display: none;\">\r\n  <div class=\"layui-btn-container\" style=\"background-color: transparent;text-align: center;\">\r\n    <button style=\"font-size: larger;margin-bottom: 15px;background-color: transparent;border-color: transparent;\" data-i18n-text=\"STRID_WEBHUB_REFRESH_TIPS\">请打开您的设备，并切换到2.4G模式；或者，请用数据线连接您的设备。</button>\r\n    <br>\r\n    <button class=\"layui-btn layui-btn-radius layui-bg-blue\" pair-action=\"refresh\" data-i18n-text=\"STRID_WEBHUB_REFRESH\">刷新</button>\r\n  </div>\r\n</div>\r\n\r\n<div id=\"not-support-panel\" style=\"display: none;background-color: transparent;text-align: center;margin-bottom: 20px;\">\r\n  <button id=\"pair-rawm-slogan\" style=\"font-size: 60px;margin-bottom: 15px;background-color: transparent;border-color: transparent;\" data-i18n-text=\"STRID_WEBHUB_RAWM_SLOGAN\">欢迎使用RAWM HUB WEB</button>\r\n  <br>\r\n  <button id=\"pair-hub-desc\" style=\"font-size: 30px;margin-bottom: 15px;background-color: transparent;border-color: transparent;\" data-i18n-text=\"STRID_WEBHUB_RAWM_HUB_DESC\">兼容Windows、Mac、Linux操作系统基于Chromium的浏览器，如Chrome、Edge</button>\r\n  <br>\r\n  <button id=\"pair-hub-detail\" style=\"font-size: 20px;margin-bottom: 15px;background-color: transparent;border-color: transparent;margin-bottom: 80px;\" data-i18n-text=\"STRID_WEBHUB_RAWM_HUB_DETAIL\">在驱动中可以根据您的习惯去调节DPI、回报率，自定义宏按键与编程等一系列配置，更多功能期待您的探索。</button>\r\n  <br>\r\n  <div class=\"layui-btn-container\" style=\"background-color: transparent;text-align: center;\">\r\n    <button style=\"font-size: larger;margin-bottom: 15px;background-color: transparent;border-color: transparent;\" data-i18n-text=\"STRID_WEBHUB_NOT_SUPPORTED\">当前浏览器不支持 RAWM HUB 网页版，推荐您使用 Edge 和 Chrome 浏览器，或者下载 RAWM HUB App。</button>\r\n  </div>\r\n</div>\r\n\r\n<div id=\"download-panel\" style=\"display: none;\">\r\n  <table style=\"margin: 15px;\">\r\n    <tr>\r\n      <td>\r\n        