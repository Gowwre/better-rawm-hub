io\" name=\"kbd-axis-mode\" value=\"1\" title=\"狂暴模式\" data-i18n-title=\"STRID_KBD_AXIS_FURY_MODE\" lay-filter=\"kbd-axis-mode\">\r\n                        </div>\r\n\r\n                        <div id=\"kbd-axis-button-container\" style=\"display: none; margin-top: 60px; margin-left: 120px;\">\r\n                          <button id=\"kbd-axis-cancel\" class=\"layui-btn layui-gray-button\"  kbd-axis-cancel-action=\"select\" data-i18n-text=\"STRING_CANCEL\">取消</button>\r\n                          <button id=\"kbd-axis-save\" class=\"layui-btn layui-bg-blue\" style=\"margin-left: 60px\" kbd-axis-save-action=\"select\" data-i18n-text=\"STRID_SAVE\">保存</button>\r\n                        </div>\r\n                      </div>\r\n\r\n                      <div style=\"width:440px; margin-left: 90px;\">\r\n                        <div class=\"layui-setting-title-container\">\r\n                          <div class=\"layui-setting-title-bar\" style=\"margin-right: 2px;\"></div>\r\n                          <p class=\"layui-setting-title\"  data-i18n-text=\"STRID_KBD_AXIS_SETTING \">性能配置</p>\r\n                        </div>\r\n                        <div class=\"layui-sub-setting-section\" style=\"width: 440px; margin-top: 10px;\">\r\n                          <p data-i18n-text=\"STRID_KBD_AXIS_TRIGGER_POINT\">触发点</p>\r\n                          <div style=\"display: flex; margin-left: 8px; margin-top: 20px;\">\r\n                            <div id=\"kbd-axis-trigger-point\" style=\"width: 400px;height: 40px; \"></div>\r\n                            <p style=\"margin-left:10px; margin-top: -6px;\">mm</p>\r\n                          </div>\r\n                          <table style=\"width: 100%;\">\r\n                            <tr>\r\n                              <td style=\"width: 100%;\">\r\n                                <p data-i18n-text=\"STRID_KBD_AXIS_QUICK_TRIGGER_MODE\">快速触发模式</p>\r\n                              </td>\r\n                              <t