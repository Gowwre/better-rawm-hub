 <tr>\r\n                            <td style=\"width:300px;height: 1px;align-items: center;justify-content: center;\">\r\n                              <div id=\"kbd-advance-key-desc-line\" style=\"width: 300px; height: 1px; background-color: gray;\">\r\n                            </td>\r\n                          </tr>\r\n                          <tr>\r\n                            <td style=\"display: flex; width:300px;height: 95px;align-items: center;justify-content: center;\">\r\n                              <p id=\"kbd-advance-key-desc1\" style=\"font-size: medium;color: gray\" data-i18n-text=\"STRID_KBD_NO_KEY_SELECTED\">未选择按键</p>\r\n                              <p id=\"kbd-advance-key-desc-arrow\" style=\"display: none; margin-left: 20px; margin-right: 20px; font: bold; font-size: large;color: gray\"> → </p>\r\n                              <p id=\"kbd-advance-key-desc2\" style=\"display: none; font-size: medium;color: #16B777\" > </p>\r\n                            </td>\r\n                          </tr>\r\n                          <tr>\r\n                            <td style=\"width:300px;height: 50px;align-items: center;justify-content: center;display: flex;\">\r\n                              <button id=\"kbd-advance-key-delete\" class=\"layui-btn layui-key-desc-button\" kbd-advance-key-delete-action=\"select\" disabled=\"disabled\" data-i18n-text=\"STRID_DELETE\">删除</button>\r\n                              <button id=\"kbd-advance-key-set\" class=\"layui-btn layui-key-desc-button\" style=\"margin-left: 90px;\" kbd-advance-key-set-action=\"select\" disabled=\"disabled\" data-i18n-text=\"STRING_OK\">确定</button>\r\n                            </td>\r\n                          </tr>\r\n                        </table>\r\n                      </div>\r\n                    </div> \r\n                  </div>\r\n                </td>\r\n              </tr>\r\n\r\n              <tr>\r\n                <td style=\"width: 100%;align-content: center;\">\r\n                  <div id=\"tab-kbd-setting-advance-key-type\" class=\"layui-tab layui-tab-brief\" lay-filter=\"kbd-setting-advance-key-type\">\r\n                    <ul id=\"kbd-advance-key-type-list\" class=\"layui-tab-title\"  style=\"width: auto;\">\r\n                      <li lay-id=\"0\" data-i18n-text=\"STRID_KBD_SOCD_SETTING\">瞬时释放(SOCD)</li>\r\n                      <li lay-id=\"1\" data-i18n-text=\"STRID_KBD_MT_SETTING\">双效点击(MT)</li>\r\n                      <li lay-id=\"2\" data-i18n-text=\"STRID_KBD_RS_SETTING\">迅捷功能(RS)</li>\r\n                      <li lay-id=\"3\" data-i18n-text=\"STRID_KBD_DKS_SETTING\">动态键程(DKS)</li>\r\n                    </ul>\r\n                    <div class=\"layui-tab-content\">\r\n                      <div class=\"layui-tab-item\">\r\n                        <div id=\"kbd-setting-socd-container\" style=\"display: none; width: auto; padding-left: 20px; padding-right: 20px;\" >\r\n                          <div style=\"display: flex; margin-top: 10px;\" >\r\n                            <p data-i18n-text=\"STRID_KBD_FUNCTION_DESC\">功能描述：</p>\r\n                            <p data-i18n-text=\"STRID_KBD_SOCD_DESC\">瞬时释放会监测两个选定的按键，并会根据你的设置触发按键。</p>\r\n                          </div>\r\n                          <div class=\"layui-setting-title-container\"  style=\"margin-top: 20px;\">\r\n                            <div class=\"layui-setting-title-bar\" style=\"margin-right: 4px;\"></div>\r\n                            <p data-i18n-text=\"STRID_KBD_SOCD_SELECT_TWO_KEY\">选择两个按键</p>\r\n                          </div>\r\n                          <div style=\"display: flex; margin-left: 60px; margin-top: 10px;\">\r\n                            <button id=\"kbd-socd-key1\" class=\"layui-btn layui-key-desc-button\" style=\"width: 100px; margin-top: 10px; border: 1px solid gray\" kbd-socd-key1-action=\"select\" data-i18n-text=\"STRID_KBD_SOCD_KEY1\">按键1</button>\r\n                            <div style=\"height: 100%; margin-left: 20px; margin-right: 20px;\">\r\n                              <p style=\"font-size: larger;margin-top: 20px; \">+</p>\r\n                            </div>\r\n                            <button id=\"kbd-socd-key2\" class=\"layui-btn layui-key-desc-button\" style=\"width: 100px; margin-top: 10px; border: 1px solid gray\" kbd-socd-key2-action=\"select\" data-i18n-text=\"STRID_KBD_SOCD_KEY2\">按键2</button>\r\n                          </div>\r\n                          <div style=\"margin-top: 20px; margin-left: 70px;\">\r\n                            <p style=\"color: gray;\" data-i18n-text=\"STRID_KBD_SOCD_HINT\">选中按键后可以点击上方键盘设置按键。</p>\r\n                          </div>\r\n                          <div class=\"layui-setting-title-container\" style=\"margin-top: 20px;\">\r\n                            <div class=\"layui-setting-title-bar\" style=\"margin-right: 4px;\"></div>\r\n                            <p data-i18n-text=\"STRID_KBD_SOCD_SELECT_FUNCTION\">选择对应的功能</p>\r\n                          </div>\r\n                          \r\n                          <div class=\"layui-form\" style=\"margin-left: 10px; margin-bottom: 10px;\">\r\n                            <input type=\"radio\" name=\"kbd-socd-type\" value=\"0\" title=\"后覆盖\" checked=true data-i18n-title=\"STRID_KBD_SOCD_TYPE1\" lay-filter=\"kbd-socd-type\">\r\n                            <input type=\"radio\" name=\"kbd-socd-type\" value=\"1\" title=\"互斥取消\" data-i18n-title=\"STRID_KBD_SOCD_TYPE2\" lay-filter=\"kbd-socd-type\">\r\n                            <input type=\"radio\" name=\"kbd-socd-type\" value=\"2\" title=\"优先按键1\" data-i18n-title=\"STRID_KBD_SOCD_TYPE3\" lay-filter=\"kbd-socd-type\">\r\n                            <input type=\"radio\" name=\"kbd-socd-type\" value=\"3\" title=\"优先按键2\" data-i18n-title=\"STRID_KBD_SOCD_TYPE4\" lay-filter=\"kbd-socd-type\">\r\n                          </div>\r\n                        </div>\r\n                      </div>\r\n                      <div class=\"layui-tab-item\">\r\n                        <div id=\"kbd-setting-mt-container\"  style=\"display: none; width: auto; padding-left: 20px; padding-right: 20px;\" >\r\n                          <div style=\"display: flex; margin-top: 10px;\" >\r\n                            <p data-i18n-text=\"STRID_KBD_FUNCTION_DESC\">功能描述：</p>\r\n                            <p data-i18n-text=\"STRID_KBD_MT_DESC\">单个按键实现两种功能：按住按键为一种，单击按键为另外一种。</p>\r\n                          </div>\r\n                          <div style=\"display: flex; margin-left: 60px; margin-top: 20px;\">\r\n                            <div style=\"align-items: center;justify-content: center;width: 100px;\">\r\n                              <p data-i18n-text=\"STRID_KBD_MT_PRESS\" style=\"text-align: center; width: 100px;\">单击</p>\r\n                              <button id=\"kbd-mt-key1\" class=\"layui-btn layui-key-desc-button\" style=\"width: 100px; margin-top: 10px; border: 1px solid gray\" kbd-mt-key1-action=\"select\" data-i18n-text=\"STRID_KBD_MT_SELECT_KEY\">选择键</button>\r\n                            </div>\r\n                            <div style=\"align-items: center;justify-content: center;width: 100px; margin-left: 60px;\">\r\n                              <p data-i18n-text=\"STRID_KBD_MT_LONGPRESS\" style=\"text-align: center; width: 100px;\">按住</p>\r\n                              <button id=\"kbd-mt-key2\" class=\"layui-btn layui-key-desc-button\" style=\"width: 100px; margin-top: 10px; border: 1px solid gray\" kbd-mt-key2-action=\"select\" data-i18n-text=\"STRID_KBD_MT_SELECT_KEY\">选择键</button>\r\n                            </div>\r\n                          </div>\r\n                          <div style=\"margin-top: 20px; margin-left: 70px;\">\r\n                            <p style=\"color: gray;\" data-i18n-text=\"STRID_KBD_MT_HINT\">请先选择上方键盘的按键后再设置按键。</p>\r\n                          </div>\r\n                          <p data-i18n-text=\"STRID_KBD_MT_LONGPRESS_TIME\" style=\"margin-top: 20px;\">手动调整按住时间</p>\r\n                          <div style=\"display: flex; margin-top: 20px; height: 30px; margin-bottom: 10px;\">\r\n                            <div id=\"kbd-mt-longpress-time\" style=\"width: 400px;\"></div>\r\n                            <p style=\"margin-left:10px; margin-top: -6px;\">ms</p>\r\n                          </div>\r\n                        </div>\r\n                      </div>\r\n                      <div class=\"layui-tab-item\">\r\n                        <div id=\"kbd-setting-rs-container\" style=\"display: none; width: auto; padding-left: 20px; padding-right: 20px;\" >\r\n                          <div style=\"display: flex; margin-top: 10px;\" >\r\n                            <p data-i18n-text=\"STRID_KBD_FUNCTION_DESC\">功能描述：</p>\r\n                            <p data-i18n-text=\"STRID_KBD_RS_DESC\">RS监控2个选定的键，并激活按下的键。例如，当A键被按下时，如果B键比A键按得更深，则B键会立即激活，一旦释放了B键，A键就会激活。</p>\r\n                          </div>\r\n                          <div class=\"layui-setting-title-container\"  style=\"margin-top: 20px;\">\r\n                            <div class=\"layui-setting-title-bar\" style=\"margin-right: 4px;\"></div>\r\n                            <p data-i18n-text=\"STRID_KBD_SOCD_SELECT_TWO_KEY\">选择两个按键</p>\r\n                          </div>\r\n                          <div style=\"display: flex; margin-left: 60px; margin-top: 10px;\">\r\n                            <button id=\"kbd-rs-key1\" class=\"layui-btn layui-key-desc-button\" style=\"width: 100px; margin-top: 10px; border: 1px solid gray\" kbd-rs-key1-action=\"select\" data-i18n-text=\"STRID_KBD_SOCD_KEY1\">按键1</button>\r\n                            <div style=\"height: 100%; margin-left: 20px; margin-right: 20px;\">\r\n                              <p style=\"font-size: larger;margin-top: 20px; \">+</p>\r\n                            </div>\r\n                            <button id=\"kbd-rs-key2\" class=\"layui-btn layui-key-desc-button\" style=\"width: 100px; margin-top: 10px; border: 1px solid gray\" kbd-rs-key2-action=\"select\" data-i18n-text=\"STRID_KBD_SOCD_KEY2\">按键2</button>\r\n                          </div>\r\n                          <div style=\"margin-top: 20px; margin-left: 70px;\">\r\n                            <p style=\"color: gray;\" data-i18n-text=\"STRID_KBD_SOCD_HINT\">选中按键后可以点击上方键盘设置按键。</p>\r\n                          </div>\r\n                        </div>\r\n                      </div>\r\n                      <div class=\"layui-tab-item\">\r\n                        <div id=\"kbd-setting-dks-container\" style=\"display: none; width: auto;\" >\r\n                          <div style=\"display: flex; margin-top: 10px; margin-left: 20px;\" >\r\n                            <p data-i18n-text=\"STRID_KBD_FUNCTION_DESC\">功能描述：</p>\r\n                            <p data-i18n-text=\"STRID_KBD_DKS_DESC\">单个按键实现四种功能:可以根据四种不同的按压程度绑定1至种功能。</p>\r\n                          </div>\r\n                          <div style=\"display: flex; margin-left: 100px; margin-top: 20px;\">\r\n                            <div style=\"width: 80px; align-items: center;justify-content: center;\">\r\n                              <p style=\"text-align: center;\" data-i18n-text=\"STRID_KBD_DKS_START_PRESS\">按压起始</p>\r\n                              <p style=\"text-align: center; color: #16B777; margin-top: 10px;\">1.00mm</p>\r\n                            </div>\r\n                            <div style=\"width: 80px; align-items: center;justify-content: center;\">\r\n                              <p style=\"text-align: center;\" data-i18n-text=\"STRID_KBD_DKS_BOTTOM_PRESS\">按压触底</p>\r\n                              <p style=\"text-align: center; color: #16B777; margin-top: 10px;\">3.40mm</p>\r\n                            </div>\r\n                            <div style=\"width: 80px; align-items: center;justify-content: center;\">\r\n                              <p style=\"text-align: center;\" data-i18n-text=\"STRID_KBD_DKS_BOTTOM_RELEASE\">触底抬起</p>\r\n                              <p style=\"text-align: center; color: #16B777; margin-top: 10px;\">3.40mm</p>\r\n                            </div>\r\n                            <div style=\"width: 80px; align-items: center;justify-content: center;\">\r\n                              <p style=\"text-align: center;\" data-i18n-text=\"STRID_KBD_DKS_FULL_RELEASE\">完全抬起</p>\r\n                              <p style=\"text-align: center; color: #16B777; margin-top: 10px;\">1.00mm</p>\r\n                            </div>\r\n                            <div style=\"width: 80px; align-items: center;justify-content: center;\">\r\n                              <p style=\"text-align: center;\" data-i18n-text=\"STRID_CLEAR\">清除</p>\r\n                            </div>\r\n                          </div>\r\n\r\n                          <div style=\"display: flex; margin-left: 20px; margin-top: 20px;\">\r\n                            <button id=\"kbd-dks-key1\" class=\"layui-btn layui-key-desc-button\" style=\"width: 80px; height: 40px; border: 1px solid gray\" keyId =\"1\" kbd-dks-select-key-action=\"select\" data-i18n-text=\"STRID_KBD_MT_SELECT_KEY\">选择键</button>\r\n                            <div id=\"kbd-dks-key1-container\" style=\"display: flex; width: 320px; height: 20px; margin-left: 30px; margin-top: 10px;\">\r\n                              <div id=\"kbd-dks-key1-4\" class=\"rounded-border\" style=\"position:absolute;width: 20px; height: 20px; margin-left: 240px; cursor: pointer;\" keyId =\"14\" kbd-dks-key-action=\"select\">\r\n                                <p id=\"kbd-dks-add1-4\" style=\"user-select: none; text-align: center; font-size: x-large; color: black; margin-top: -4px;\">+</p>\r\n                                <div id=\"kbd-dks-arrow1-4\" style=\"display: none; position:absolute;width: 10px; height: 20px; margin-left: 14px; cursor: e-resize;\" keyId =\"14\" kbd-dks-key-arrow-action=\"select\">\r\n                                  <p style=\"user-select: none; text-align: center; font-size: x-large; font: bold; color: white; margin-top: -5px;\">›</p>\r\n                                </div>\r\n                              </div>\r\n                              <div id=\"kbd-dks-key1-3\" class=\"rounded-border\" style=\"position:absolute;width: 20px; height: 20px;margin-left: 160px; cursor: pointer;\" keyId =\"13\" kbd-dks-key-action=\"select\">\r\n                                <p id=\"kbd-dks-add1-3\" style=\"text-align: center; font-size: x-large; color: black; margin-top: -4px;\">+</p>\r\n                                <div id=\"kbd-dks-arrow1-3\" style=\"display: none;  position:absolute;width: 10px; height: 20px; margin-left: 14px; cursor: e-resize;\" keyId =\"13\" kbd-dks-key-arrow-action=\"select\">\r\n                                  <p style=\"user-select: none; text-align: center; font-size: x-large; font: bold; color: white; margin-top: -5px;\">›</p>\r\n                                </div>\r\n                              </div>\r\n                              <div id=\"kbd-dks-key1-2\" class=\"rounded-border\" style=\"position:absolute; width: 20px; height: 20px; margin-left: 80px; cursor: pointer;\" keyId =\"12\" kbd-dks-key-action=\"select\">\r\n                                <p id=\"kbd-dks-add1-2\" style=\"text-align: center; font-size: x-large; color: black; margin-top: -4px;\">+</p>\r\n                                <div id=\"kbd-dks-arrow1-2\" style=\"display: none; position:absolute;width: 10px; height: 20px; margin-left: 14px; cursor: e-resize;\" keyId =\"12\" kbd-dks-key-arrow-action=\"select\">\r\n                                  <p style=\"user-select: none;text-align: center; font-size: x-large; font: bold; color: white; margin-top: -5px;\">›</p>\r\n                                </div>\r\n                              </div>\r\n                              <div id=\"kbd-dks-key1-1\" class=\"rounded-border\" style=\"position:absolute;width: 20px; height: 20px; cursor: pointer;\" keyId =\"11\" kbd-dks-key-action=\"select\">\r\n                                <p id=\"kbd-dks-add1-1\" style=\"user-select: none;text-align: center; font-size: x-large; color: black; margin-top: -4px;\">+</p>\r\n                                <div id=\"kbd-dks-arrow1-1\" style=\"display: none; position:absolute;width: 10px; height: 20px; margin-left: 14px; cursor: e-resize;\" keyId =\"11\" kbd-dks-key-arrow-action=\"select\">\r\n                                  <p style=\"user-select: none; text-align: center; font-size: x-large; font: bold; color: white; margin-top: -5px;\">›</p>\r\n                                </div>\r\n                              </div>\r\n                              <div id=\"kbd-dks-clean1\" class=\"rounded-border\" style=\"position:absolute;width: 20px; height: 20px;margin-left: 320px; cursor: pointer;\" keyId =\"1\" kbd-dks-clean-action=\"select\">\r\n                                <p style=\"text-align: center; font-size: x-large; color: black; margin-top: -3px;\">×</p>\r\n                              </div>\r\n                            </div>\r\n                          </div>\r\n                          <div style=\"display: flex; margin-left: 20px; margin-top: 20px;\">\r\n                            <button id=\"kbd-dks-key2\" class=\"layui-btn layui-key-desc-button\" style=\"width: 80px; height: 40px; border: 1px solid gray\" keyId =\"2\" kbd-dks-select-key-action=\"select\" data-i18n-text=\"STRID_KBD_MT_SELECT_KEY\">选择键</button>\r\n                            <div id=\"kbd-dks-key2-container\" style=\"display: flex; width: 320px; height: 20px; margin-left: 30px; margin-top: 10px;\">\r\n                              <div id=\"kbd-dks-key2-4\" class=\"rounded-border\" style=\"position:absolute;width: 20px; height: 20px; margin-left: 240px; cursor: pointer;\" keyId =\"24\" kbd-dks-key-action=\"select\">\r\n                                <p id=\"kbd-dks-add2-4\" style=\"user-select: none; text-align: center; font-size: x-large; color: black; margin-top: -4px;\">+</p>\r\n                                <div id=\"kbd-dks-arrow2-4\" style=\"display: none; position:absolute;width: 10px; height: 20px; margin-left: 14px; cursor: e-resize;\" keyId =\"24\" kbd-dks-key-arrow-action=\"select\">\r\n                                  <p style=\"user-select: none; text-align: center; font-size: x-large; font: bold; color: white; margin-top: -5px;\">›</p>\r\n                                </div>\r\n                              </div>\r\n                              <div id=\"kbd-dks-key2-3\" class=\"rounded-border\" style=\"position:absolute;width: 20px; height: 20px;margin-left: 160px; cursor: pointer;\" keyId =\"23\" kbd-dks-key-action=\"select\">\r\n                                <p id=\"kbd-dks-add2-3\" style=\"text-align: center; font-size: x-large; color: black; margin-top: -4px;\">+</p>\r\n                                <div id=\"kbd-dks-arrow2-3\" style=\"display: none;  position:absolute;width: 10px; height: 20px; margin-left: 14px; cursor: e-resize;\" keyId =\"23\" kbd-dks-key-arrow-action=\"select\">\r\n                                  <p style=\"user-select: none; text-align: center; font-size: x-large; font: bold; color: white; margin-top: -5px;\">›</p>\r\n                                </div>\r\n                              </div>\r\n                              <div id=\"kbd-dks-key2-2\" class=\"rounded-border\" style=\"position:absolute; width: 20px; height: 20px; margin-left: 80px; cursor: pointer;\" keyId =\"22\" kbd-dks-key-action=\"select\">\r\n                                <p id=\"kbd-dks-add2-2\" style=\"text-align: center; font-size: x-large; color: black; margin-top: -4px;\">+</p>\r\n                                <div id=\"kbd-dks-arrow2-2\" style=\"display: none; position:absolute;width: 10px; height: 20px; margin-left: 14px; cursor: e-resize;\" keyId =\"22\" kbd-dks-key-arrow-action=\"select\">\r\n                                  <p style=\"user-select: none;text-align: center; font-size: x-large; font: bold; color: white; margin-top: -5px;\">›</p>\r\n                                </div>\r\n                              </div>\r\n                              <div id=\"kbd-dks-key2-1\" class=\"rounded-border\" style=\"position:absolute;width: 20px; height: 20px; cursor: pointer;\" keyId =\"21\" kbd-dks-key-action=\"select\">\r\n                                <p id=\"kbd-dks-add2-1\" style=\"user-select: none;text-align: center; font-size: x-large; color: black; margin-top: -4px;\">+</p>\r\n                                <div id=\"kbd-dks-arrow2-1\" style=\"display: none; position:absolute;width: 10px; height: 20px; margin-left: 14px; cursor: e-resize;\" keyId =\"21\" kbd-dks-key-arrow-action=\"select\">\r\n                                  <p style=\"user-select: none; text-align: center; font-size: x-large; font: bold; color: white; margin-top: -5px;\">›</p>\r\n                                </div>\r\n                              </div>\r\n                              <div id=\"kbd-dks-clean2\" class=\"rounded-border\" style=\"position:absolute;width: 20px; height: 20px;margin-left: 320px; cursor: pointer;\" keyId =\"2\" kbd-dks-clean-action=\"select\">\r\n                                <p style=\"text-align: center; font-size: x-large; color: black; margin-top: -3px;\">×</p>\r\n                              </div>\r\n                            </div>\r\n                          </div>\r\n                          <div style=\"display: flex; margin-left: 20px; margin-top: 20px;\">\r\n                            <button id=\"kbd-dks-key3\" class=\"layui-btn layui-key-desc-button\" style=\"width: 80px; height: 40px; border: 1px solid gray\" keyId =\"3\" kbd-dks-select-key-action=\"select\" data-i18n-text=\"STRID_KBD_MT_SELECT_KEY\">选择键</button>\r\n                            <div id=\"kbd-dks-key3-container\" style=\"display: flex; width: 320px; height: 20px; margin-left: 30px; margin-top: 10px;\">\r\n                              <div id=\"kbd-dks-key3-4\" class=\"rounded-border\" style=\"position:absolute;width: 20px; height: 20px; margin-left: 240px; cursor: pointer;\" keyId =\"34\" kbd-dks-key-action=\"select\">\r\n                                <p id=\"kbd-dks-add3-4\" style=\"user-select: none; text-align: center; font-size: x-large; color: black; margin-top: -4px;\">+</p>\r\n                                <div id=\"kbd-dks-arrow3-4\" style=\"display: none; position:absolute;width: 10px; height: 20px; margin-left: 14px; cursor: e-resize;\" keyId =\"34\" kbd-dks-key-arrow-action=\"select\">\r\n                                  <p style=\"user-select: none; text-align: center; font-size: x-large; font: bold; color: white; margin-top: -5px;\">›</p>\r\n                                </div>\r\n                              </div>\r\n                              <div id=\"kbd-dks-key3-3\" class=\"rounded-border\" style=\"position:absolute;width: 20px; height: 20px;margin-left: 160px; cursor: pointer;\" keyId =\"33\" kbd-dks-key-action=\"select\">\r\n                                <p id=\"kbd-dks-add3-3\" style=\"text-align: center; font-size: x-large; color: black; margin-top: -4px;\">+</p>\r\n                                <div id=\"kbd-dks-arrow3-3\" style=\"display: none;  position:absolute;width: 10px; height: 20px; margin-left: 14px; cursor: e-resize;\" keyId =\"33\" kbd-dks-key-arrow-action=\"select\">\r\n                                  <p style=\"user-select: none; text-align: center; font-size: x-large; font: bold; color: white; margin-top: -5px;\">›</p>\r\n                                </div>\r\n                              </div>\r\n                              <div id=\"kbd-dks-key3-2\" class=\"rounded-border\" style=\"position:absolute; width: 20px; height: 20px; margin-left: 80px; cursor: pointer;\" keyId =\"32\" kbd-dks-key-action=\"select\">\r\n                                <p id=\"kbd-dks-add3-