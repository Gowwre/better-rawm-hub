            "text": ";String resources in English \r\n;Example:\r\n;STRID_MAINWINDOW_BUTTON_LOGIN = Login\r\n;TIPID_MAINWINDOW_BUTTON_LOGIN = Click to login\r\n;comment symbolï¼šâ€œ;â€\r\n;ruleï¼šEvery window uses its own strings. One windows is not permitted to use strings of other windows'.\r\n\r\n;Common\r\nSTRING_OK = OK\r\nSTRING_CANCEL = Cancel\r\n\r\n;cef Browser\r\nSTRID_CEF_BROWSER_WINDOW_MODE = Windowed Cef browser component test\r\nSTRID_CEF_BROWSER_BACKWARD = Back\r\nSTRID_CEF_BROWSER_FORWARD = Forward\r\nSTRID_CEF_BROWSER_INPUT_ADDRESS = Enter address\r\nSTRID_CEF_BROWSER_BROWSE_TO = Go to\r\nSTRID_CEF_BROWSER_REFRESH = Refresh\r\nSTRID_CEF_BROWSER_HELLO_JS = Hello JS!\r\nSTRID_CEF_BROWSER_INPUT_TEXT = Enter text to send to JS\r\nSTRID_CEF_BROWSER_SEND_TO_JS = Send to JS\r\nSTRID_CEF_BROWSER_OFF_SCREEN_MODE = Off-screen rendering Cef browser component test\r\nSTRID_CEF_BROWSER_RECEIVE_JS_MSG = Received message from JS: %s\r\nSTRID_CEF_BROWSER_MULTI_TAB = Draggable multi-tab browser\r\nSTRID_CEF_BROWSER_CLOSING = The current window contains multiple tabs. Are you sure you want to close it?\r\n\r\n;RAWM\r\nSTRID_APP_TITLE = RAWMHUB\r\n\r\nSTRID_TITLE_WARNING = Warning\r\nSTRID_BUTTON_CANCEL = Cancel\r\n\r\nSTRID_HOME_NAV_HOME = Home\r\nSTRID_HOME_NAV_GAME = Games and Applications\r\nSTRID_HOME_NAV_DISCUSS = Community\r\nSTRID_HOME_NAV_RESOURCE = Resources\r\nSTRID_HOME_NAV_SETTING = Settings\r\nSTRID_HOME_INITIALIZING_DEVICE_CFG\t= Updating product information...\r\nSTRID_HOME_NO_PRODUCT_CONNECTED = Not connected to any RAWM products\r\nSTRID_HOME_UNKNOWN_PRODUCT_CONNECTED = Connected, reading product information...\r\nSTRID_HOME_PRODUCT_FIRMWARE = FW:\r\nSTRID_HOME_PRODUCT_NEW_FIRMWARE = New firmware available\r\nSTRID_HOME_FW_UPGRADE_TITLE = New firmware\r\nSTRID_HOME_FW_UPGRADE_CONFIRM = Are you sure you want to upgrade to the new firmware?\r\nSTRID_HOME_FW_UPGRADE_LOCAL_MODE = - Local upgrade package -\r\nSTRID_UPGRADE = Upgrade\r\nSTRID_DFU_NOT_USB_MODE = Please connect the mouse with a data cable before upgrading to the new firmware!\r\nSTRID_UPGRADING = Do not unplug %s's data cable, as it may be damaged and unusable!\r\nSTRID_DFU_DOWNLOAD_FAILED = Failed to download the upgrade package! Please check your network!\r\nSTRID_DFU_WAIT_COM_FAILED = Upgrade failed! Unplug the data cable, toggle %s's bottom switch, and restart it!\r\nSTRID_DFU_UNKNOWN_FAILED = Upgrade failed! Unplug the data cable, toggle %s's bottom switch, and restart it!\r\nSTRID_DFU_STEP_DOWNLOADING = Downloading the upgrade package...\r\nSTRID_DFU_STEP_WAITING_COM = Restarting device to enter upgrade mode...\r\nSTRID_DFU_STEP_PREPARE = Preparing for upgrade...\r\nSTRID_DFU_STEP_FLASHING = Upgrading...\r\nSTRID_DEVICE_DFU_ONLY = This device is in abnormal state. You must upgrade it to the latest firmware to use it normally!\r\nSTRID_DEVICE_DFU_ONLY_FOUND = Found %s in abnormal state. You must upgrade it to the latest firmware to use it normally!\r\nSTRID_DFU_RE_POWER_NEEDED = Upgrade completed! Please unplug/plug the data/power cable to restart the device!\r\nSTRID_DEVICE_SYNCING = Syncing device data, please wait...\\nIf it takes too long, restart or restore the device.\r\n\r\nSTRID_SET_DEVICE_NAME_TITLE = Rename\r\nSTRID_SET_DEVICE_NAME_TIPS = Please enter the device name\r\n\r\nSTRID_HOME_VER = Version:\r\nSTRID_HOME_VER_UPGRADE_TITLE = New version\r\nSTRID_HOME_NEW_VER_AVAIL = New version available\r\nSTRID_VER_UPGRADING = Upgrading to the new version; it will automatically restart afterward.\r\n\r\nSTRID_SETTING_DPI = Sensitivity (DPI)\r\nSTRID_SETTING_DPI_SPEED = DPI Speed\r\nSTRID_SETTING_DPI_SPEED_INPUT = Enter a value\r\nSTRID_SETTING_DPI_SPEED_DESC = DPI/CPI (dots per inch) for mouse movement. You can modify/delete values by clicking on the level in edit mode.\r\nSTRID_SETTING_DPI_BOTH_X_Y = Set X and Y values separately\r\nSTRID_SETTING_DPI_LEVEL_SPEED_INPUT = Enter level value\r\nSTRID_SETTING_DPI_LEVEL_SPEED_INPUT_XY = Enter X and Y values for the level\r\nSTRID_SETTING_DPI_DELETE_CONFIRM = Are you sure you want to delete this level value?\r\nSTRID_SETTING_DPI_LEVEL = Level\r\nSTRID_SETTING_DPI_LEVEL_ADD = Add\r\nSTRID_SETTING_DPI_COPY = Copy DPI\r\nSTRID_SETTING_DPI_COPY_DETECT_SOURCE = Please keep moving the mouse of copy source...\r\nSTRID_SETTING_DPI_COPY_WAITING\t= Collecting moving data...\r\nSTRID_SETTING_DPI_COPY_TIPS = Pin the two mice together, press S key, then keep moving both mice till the ratio reaching near 1.0, press P key to complete the copy.\r\nSTRID_SETTING_DPI_COPY_ERROR = Too many mice!\r\nSTRID_SETTING_DPI_COPY_DONE = Copied\r\nSTRID_SETTING_POLLING_RATE = Polling Rate (per second)\r\nSTRID_SETTING_POLLING_RATE_DESC = Also known as report rate, the mouse's data update frequency. After modification, the mouse needs to be rebooted for the changes to take effect.\r\nSTRID_SETTING_POLLING_RATE_NOT_SUPPORTED = Current receiver or performance mode does not support this polling rate!\r\nSTRID_SETTING_POLLING_RATE_GLASS_MODE = Glass surface mode activated\r\nSTRID_SETTING_POLLING_RATE_ENABLE_GLASS_MODE = Glass Mode\r\nSTRID_SETTING_FACTORY_RESET = Restore\r\nSTRID_SETTING_FACTORY_RESET_S = Restore\r\nSTRID_SETTING_FACTORY_RESET_WARNING = This operation will completely delete all configuration data inside the mouse and restore it to the factory state. It cannot be undone. Are you sure?\r\nSTRID_SETTING_FACTORY_RESET_ESB = Delete pairing data with the USB receiver\r\nSTRID_SETTING_MOUSE_REBOOT = Reboot\r\nSTRID_SETTING_MOUSE_REBOOT_S = Reboot\r\nSTRID_SETTING_MOUSE_REBOOT_WARNING = Are you sure to restart the mouse?\r\nSTRID_SETTING_MOUSE_REBOOT_NEEDED = Polling rate/report rate has been modified. The mouse needs to be restarted for the changes to take effect!\r\nSTRID_SETTING_MOUSE_PAIR_WARNING = Are you sure to pair {name1} with {name2}?\r\nSTRID_SETTING_MOUSE_PAIR_S = Pair\r\nSTRID_SETTING_MOUSE_UNPAIR_WARNING = Are you sure to unpair {name1} from {name2}?\r\nSTRID_SETTING_MOUSE_UNPAIR_BLE_WARNING\t= Are you sure to unpair{name1} from BLE host ({name2})?\r\nSTRID_SETTING_MOUSE_UNPAIR_S = Unpair\r\nSTRID_SETTING_MOUSE_PAIRED_SELECT_S = Switch\r\nSTRID_SETTING_MOUSE_GOM_REBOOT_NEEDED = To modify firmware channel, the mouse needs to be restarted for the changes to take effect!\r\nSTRID_SETTING_MOUSE_ONBOARD_REBOOT_NEEDED\t= Failed to read {name1}'s onboard settings. Please restart the mouse or reset to factory settings!\r\nSTRID_SETTING_MOUSE_AUTO_POWER_SAVING\t= Power Saving\r\nSTRID_SETTING_MOUSE_CAN_NOT_PAIR_WARNING = {name1} and {name2} are not compatible, pairing not possible!\r\n\r\nSTRID_SETTING_LIGHT = Light\r\nSTRID_SETTING_LIGHT_AUTO_OFF = Automatically turns off when idle\r\nSTRID_SETTING_LIGHT_LOOP = Loop\r\nSTRID_SETTING_LIGHT_DEFINE = Customize\r\nSTRID_SETTING_LIGHT_MODE = DPI levels\r\nSTRID_SETTING_LIGHT_RED = Red\r\nSTRID_SETTING_LIGHT_GREEN = Green\r\nSTRID_SETTING_LIGHT_BLUE = Blue\r\nSTRID_SETTING_LIGHT_BRIGHTNESS\t= Brightness\r\nSTRID_SETTING_CONFIG_DEFAULT = Default config\r\nSTRID_SETTING_CONFIG_CURRENT = Onboard config \r\nSTRID_SETTING_CONFIG_CURRENT_S = Onboard \r\nSTRID_SETTING_CONFIG_CURRENT_DESC = Onboard config permanently stored in the mouse's memory\r\nSTRID_SETTING_CONFIG_CURRENT_ALLOW_SWITCH = Switchable\r\nSTRID_SETTING_ADD_CONFIG = Add config\r\nSTRID_SETTING_SAME_CONFIG_EXISTED = A configuration with the same name already exists!\r\nSTRID_SETTING_IMPORT_CONFIG = Import config\r\nSTRID_SETTING_EXPORT_CONFIG = Export config\r\nSTRID_SETTING_SHARE_CONFIG = Share config\r\nSTRID_SETTING_APPLY_CONFIG = Apply config\r\nSTRID_SETTING_INPUT_CONFIG_NAME = Config name\r\nSTRID_SETTING_INPUT_CONFIG_AUTHOR = Config author's name\r\nSTRID_SETTING_INPUT_CONFIG_DESC = Config description\r\nSTRID_SETTING_INPUT_ADDRESS = Please enter the ID of the computer to bind\r\nSTRID_SETTING_DELETE_CONFIG_WARNING = Are you sure you want to delete this configuration?\r\nSTRID_SETTINGD_DESTROY_AFTER_IMPORTED = Use and discard\r\nSTRID_SETTINGD_LOCK_AFTER_IMPORTED = Prevent further sharing or exporting\r\nSTRID_SETTINGD_CONFIG_LOCK_WARNING = The imported key mapping configuration cannot be shared or exported again\r\nSTRID_SETTINGD_CONFIG_NAME = Name:\r\nSTRID_SETTINGD_CONFIG_AUTHOR = Author:\r\nSTRID_SETTINGD_CONFIG_DESC = Description:\r\nSTRID_SETTINGD_CONFIG_ADDRESS = Address:\r\nSTRID_SETTINGD_CONFIG_COPY_AND_OPEN = Please copy the share code and import it in RAWMHUB\r\nSTRID_SETTINGD_IMPORT_CONFIG_IN_GAME = Please import the configuration in the settings!\r\nSTRID_SETTINGD_CONFIG_EMPTY = No configurations available for import\r\nSTRID_SETTINGD_CONFIG_EXPORTED = Configuration exported successfully\r\nSTRID_SETTINGD_INPUT_CONFIG_NAME = Please enter a configuration name\r\nSTRID_SETTINGD_KEY_COMBINATION_LABEL = R-Plus Key\r\nSTRID_SETTINGD_KEY_COMBINATION_DESC = Press and hold the R-Plus key while pressing other keys to trigger secondary mappings\r\n\r\nSTRID_SETTING_MAPPING = Mapping\r\nSTRID_SETTING_MAPPING_TYPE = Mapping Type\r\nSTRID_SETTING_MAPPING_TYPE_KEY = Key\r\nSTRID_SETTING_MAPPING_TYPE_ASSIST = Assist\r\nSTRID_SETTING_MAPPING_TYPE_MACRO = Macro\r\nSTRID_SETTING_MAPPING_TYPE_FUNCTION = Function\r\nSTRID_SETTING_MAPPING_DELETE = Delete\r\nSTRID_SETTING_MAPPING_ADD = New\r\nSTRID_SETTING_MAPPING_IMPORT = Import\r\nSTRID_SETTING_MAPPING_EXPORT = Export\r\nSTRID_SETTING_MAPPING_UPLOAD = Upload\r\nSTRID_SETTING_MAPPING_SAVE_AS = Save as\r\nSTRID_SETTING_MAPPING_SAVE_AND_APPLY = Save\r\nSTRID_SETTING_MAPPING_SAVE_TO_FDS_CONFIRM = Do you want to permanently save the configuration to the mouse's onboard memory?\r\nSTRID_SETTING_MAPPING_SAVE_TO_FDS_S = Onboard\r\nSTRID_SETTING_MAPPING_NOT_SAVE_TO_FDS_S = Apply only\r\nSTRID_SETTING_MAPPING_DELETE_CONFIRM = Are you sure you want to delete this configuration?\r\nSTRID_SETTING_MAPPING_SAVED = Successfully saved\r\nSTRID_SETTING_MAPPING_APPLY_AND_ONBOARD = Apply & onboard\r\nSTRID_SETTING_MAPPING_ONBOARD_INDEX = Location\r\nSTRID_SETTING_MAPPING_LOCAL_SAVE_TO_FDS_CONFIRM = Successfully saved\\nDo you want to permanently save the configuration to the mouse's onboard memory?\r\nSTRID_SETTING_MAPPING_LOCAL_NOT_SAVE_TO_FDS_S = Not want\r\n\r\nSTRID_SETTING_MAPPING_BOTTOM_KEY = Bottom\r\n\r\nSTRID_SETTING_MAPPING_SELECT_KEY = Select Key\r\nSTRID_SETTING_MAPPING_CTRL_KEY = Control Key\r\nSTRID_SETTING_MAPPING_KEY_INPUT_TIPS = Click to capture key\r\nSTRID_SETTING_MAPPING_KEY_INPUT_CANCEL_TIPS = Click to cancel key capture\r\nSTRID_SETTING_MAPPING_KEY_CLEAN = Clear key\r\nSTRID_SETTING_MAPPING_KEY_CMD = Command\r\nSTRID_SETTING_MAPPING_KEY_RECORD = Record\r\nSTRID_SETTING_MAPPING_KEY_RECORD_TITLE = Key recording\r\nSTRID_SETTING_MAPPING_KEY_RECORD_WAITING = Please input by keyboard/mouse... When inputting by mouse, ensure that the mouse pointer is within this window!\\n\\n\r\nSTRID_SETTING_MAPPING_KEY_RECORD_WAITING_EX = Please input by keyboard/mouse...\\n\\n\r\nSTRID_SETTING_MAPPING_KEY_RECORD_RESET = Reset\r\nSTRID_SETTING_MAPPING_KEY_TURBO = Turbo (uinit ms)\r\nSTRID_SETTING_MAPPING_KEY_TURBO_FREQ = CPS\r\nSTRID_SETTING_MAPPING_KEY_TURBO_RAND = Random\r\nSTRID_SETTING_MAPPING_KEY_TURBO_DOWN_KEEP = Press\r\nSTRID_SETTING_MAPPING_KEY_TURBO_UP_KEEP = Release\r\n\r\nSTRID_SETTING_MAPPING_TOGGLE_KEY = Toggle Key\r\nSTRID_SETTING_MAPPING_TOGGLE_KEY2 = Toggle Key:\r\nSTRID_SETTING_MAPPING_TOGGLE_LIGHT = Synchronize light toggle\r\nSTRID_SETTING_MAPPING_INTENSITY_SUMMARY = After enabling assist shooting, the view will automatically move downward. You can adjust the intensity value to control the downward speed. Suitable for shooting games, making your shots more accurate. Adjust the intensity based on the gun's recoil:\r\nSTRID_SETTING_MAPPING_INTENSITY1 = Intensity 1\r\nSTRID_SETTING_MAPPING_INTENSITY2 = Intensity 2\r\nSTRID_SETTING_MAPPING_INTENSITY3 = Intensity 3\r\nSTRID_SETTING_MAPPING_INTENSITY4 = Intensity 4\r\nSTRID_SETTING_MAPPING_INTENSITY5 = Intensity 5\r\nSTRID_SETTING_MAPPING_INTENSITY_SELECT_KEY = Activate key:\r\nSTRID_SETTING_MAPPING_AUTO_CLICK = Auto-click\r\n\r\nSTRID_SETTING_MAPPING_MACRO = Macro\r\nSTRID_SETTING_MAPPING_MACRO_TRIGGER_TYPE = Trigger Type:\r\nSTRID_SETTING_MAPPING_MACRO_STOP_KEY = Stop Key:\r\nSTRID_SETTING_MAPPING_MACRO_ACTIONS = Total %d actions\r\nSTRID_SETTING_MAPPING_MACRO_TRIGGER_PRESS = Press\r\nSTRID_SETTING_MAPPING_MACRO_TRIGGER_RELEASE = Release\r\nSTRID_SETTING_MAPPING_MACRO_TRIGGER_LOOP = Press hold loop\r\nSTRID_SETTING_MAPPING_MACRO_TRIGGER_LONG_PRESS = Long press\r\nSTRID_SETTING_MAPPING_MACRO_TRIGGER_LONG_LOOP = Long press hold loop\r\nSTRID_SETTING_MAPPING_MACRO_TRIGGER_LONG_RELEASE = Long press release\r\nSTRID_SETTING_MAPPING_MACRO_TRIGGER_TOGGLE_LOOP = Click loop\r\nSTRID_SETTING_MAPPING_MACRO_TRIGGER_TOGGLE_LOOP_WARNING = You must specify a stop key for the click loop macro\r\n\r\nSTRID_SETTING_MAPPING_MACRO_EDIT = Edit macro\r\nSTRID_SETTING_MAPPING_MACRO_RECORD = Record\r\nSTRID_SETTING_MAPPING_MACRO_RECORD_TITLE = Key recording\r\nSTRID_SETTING_MAPPING_MACRO_RECORD_WAITING = Please input by keyboard/mouse... When inputting by mouse, ensure that the mouse pointer is within this window!\r\nSTRID_SETTING_MAPPING_MACRO_RECORD_MAX = Please input by keyboard/mouse... Reached the maximum number of actions! When inputting by mouse, ensure that the mouse pointer is within this window!\r\nSTRID_SETTING_MAPPING_MACRO_RECORD_WAITING_EX = Please input by keyboard/mouse...\r\nSTRID_SETTING_MAPPING_MACRO_RECORD_MAX_EX = Please input by keyboard/mouse... Reached the maximum number of actions!\r\nSTRID_SETTING_MAPPING_MACRO_RECORD_FIXED_TIME = Use standard action interval: 50 ms\r\nSTRID_SETTING_MAPPING_MACRO_RECORD_INCLUDE_MOVE = Record mouse move\r\nSTRID_SETTING_MAPPING_MACRO_RECORD_SHORTCUT = Record shortcut\r\nSTRID_SETTING_MAPPING_MACRO_RECORD_SHORTCUT_EDIT = Change\r\nSTRID_SETTING_MAPPING_MACRO_RECORD_SHORTCUT_EDITING = Please press shortcut\r\nSTRID_SETTING_MAPPING_MACRO_RECORD_STOPPED = Please press shortcut to start record