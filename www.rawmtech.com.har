      justify-content: center;\r\n      align-items: center;\r\n      z-index: 9999; /* 确保在最上层 */\r\n  }\r\n  </style>\r\n</head>\r\n<body oncontextmenu=self.event.returnValue=false>\r\n<div class=\"layui-logo layui-auto-zoom\">\r\n  <img id=\"logo\" src=\"https://hub.miracletek.net/hub/img/rawm_hub.png?v=202412080015\" style=\"position: absolute;margin-left: 20px;margin-top: 10px;\"/>\r\n  <button id=\"back-home\" class=\"layui-btn layui-btn-radius layui-bg-blue\" style=\"position: absolute;margin-left: 10px;margin-top: 15px; display: none;\" setting-action=\"back\" data-i18n-text=\"STRID_SETTING_MAPPING_NOT_SAVED_BACK_S\">返回</button>\r\n</div>\r\n<div id=\"pair-more-panel\" class=\"layui-pair-more layui-auto-zoom\">\r\n  <div class=\"layui-form\" id=\"language-form\" style=\"margin-right: 15px;\">\r\n    <div id=\"kbd-setting-onboard-config\" class=\"layui-input-inline\" style=\"width: 120px; height: 40px; display: none;\"></div>\r\n  </div>\r\n  <button id=\"pair-more\" class=\"layui-btn layui-btn-radius layui-bg-blue\" style=\"display: none;\" pair-action=\"pair-more\" data-i18n-text=\"STRID_WEBHUB_CONNECT_MORE_DEVICES\">连接更多设备</button>\r\n  <button id=\"download\" class=\"layui-btn layui-btn-radius layui-bg-blue\" download-action=\"download\" data-i18n-text=\"STRID_WEBHUB_DOWNLOAD_APP\">下载 APP</button>\r\n  <div class=\"layui-form\" id=\"language-form\" style=\"margin-left: 15px;\">\r\n    <div class=\"layui-input-inline\" style=\"width: 100px;\">\r\n      <select name=\"language\" lay-verify=\"required\" lay-filter=\"language\">\r\n        <option value=\"\" data-i18n-text=\"STRID_WEBHUB_SYSTEM_LANGUAGE\">系统语言</option>\r\n        <option value=\"zh_CN\">简体中文</option>\r\n        <option value=\"en_US\">English</option>\r\n        <option value=\"zh_TW\">繁體中文</option>\r\n        <option value=\"ko_KR\">한국어</option>\r\n        <option value=\"ja_JP\">日本語</option>\r\n        <option value=\"uk_UA\">Українська</option>\r\n        <option value=\"tr_TR\">Türkçe</option>\r\n      </select>\r\n    </div>\r\n    <div class=\"layui-input-inline\" style=\"margin-left: 10px;padding-bottom: 7px;\">\r\n      <input type=\"checkbox\" name=\"dark-theme\" lay-skin=\"switch\" lay-filter=\"dark-theme\" title=\"深色|浅色\" data-i18n-title=\"STRID_WEBHUB_THEME_STYLE\">\r\n    </div>\r\n  </div>\r\n</div>\r\n\r\n<div id=\"usb-client-channel\" class=\"layui-container layui-auto-zoom\" style=\"z-index: 1000;width: fit-content;left: 50%;transform: translateX(-50%); position: absolute;display: none;\">\r\n  <table>\r\n    <tr>\r\n      <td>\r\n        <p data-i18n-text=\"STRID_SETTING_FW_CHANNEL\" style=\"margin-right: 10px;margin-top: 4px;\">固件通道</p>\r\n      </td>\r\n      <td>\r\n        <div class=\"layui-form\">\r\n          <input type=\"radio\" name=\"setting-fw-channel\" value=\"0\" title=\"标准\" data-i18n-title=\"STRID_SETTING_FW_CHANNEL_STANDARD\" lay-filter=\"setting-fw-channel\">\r\n          <input type=\"radio\" name=\"setting-fw-channel\" value=\"1\" title=\"竞技\" data-i18n-title=\"STRID_SETTING_FW_CHANNEL_GAME_ONLY\" lay-filter=\"setting-fw-channel\"> \r\n        </div>\r\n      </td>\r\n    </tr>\r\n  </table>\r\n</div>\r\n\r\n<div id=\"usb-client-list-panel\" class=\"layui-container layui-auto-zoom\" style=\"width: 100%;\">\r\n  <div id=\"usb-client-list\" class=\"layui-nav-container\"></div>\r\n</div>\r\n\r\n<div id=\"current-usb-client-panel\" class=\"layui-current-panel layui-auto-zoom\" style=\"display: none;\">\r\n  <div style=\"position: absolute;width: 419px;height: 504px;\">\r\n    <p id=\"current-usb-client-name\" class=\"layui-current-name\"></p>\r\n    <p id=\"current-usb-client-name-model\" class=\"layui-current-name\" style=\"margin-top: 25px;font-size: 15px;\"></p>\r\n    <img id=\"current-usb-client-battery-icon\" src=\"\" style=\"position: absolute;left: 325px;top: 40px;\"/>\r\n    <p id=\"current-usb-client-battery\" style=\"position: absolute;left: 324px;top: 43px;width: 47px;text-align: center;font-size: 15px;\"></p>\r\n    <img id=\"current-usb-client-rssi-icon\" src=\"\" style=\"position: absolute;left: 285px;top: 40px;\"/>\r\n  </div>\r\n  <div style=\"position: absolute;display: flex;align-items: center;justify-content: center;width: 419px;height: 504px;\">\r\n    <img id=\"current-usb-client-image\" src=\"\" style=\"position: absolute;cursor: pointer;\" current-action=\"edit\"/>\r\n    <div id=\"current-usb-client-models\" style=\"position: absolute;margin-top: 310px;text-align: center;width: fit-content;\">\r\n    </div>\r\n    <table style=\"text-align: center;align-self: end;margin-bottom: 30px;\">\r\n      <tr>\r\n        <td>\r\n          <p id=\"current-usb-client-firmware\" style=\"font-size: 14px;color: #303030\"></p>\r\n        </td>\r\n      </tr>\r\n      <tr>\r\n        <td>\r\n          <p id=\"current-usb-client-firmware-new\" class=\"layui-firmware-new\" style=\"color: #16B777;\" firmware-action=\"click\" data-i18n-text=\"STRID_HOME_NEW_VER_AVAIL\">有新的版本可用</p>\r\n        </td>\r\n      </tr>\r\n    </table>\r\n  </div>\r\n</div>\r\n<div id=\"kbd-current-usb-client-panel\" class=\"layui-current-panel layui-auto-zoom\" style=\"display: none; width: 626px;\">\r\n  <div style=\"position: absolute;width: 626px;height: 482px;\">\r\n    <p id=\"kbd-current-usb-client-name\" class=\"layui-current-name\"></p>\r\n  </div>\r\n  <div style=\"position: absolute;display: flex;align-items: center;justify-content: center;width: 626px;height: 482px;\">\r\n    <img id=\"kbd-current-usb-client-image\" src=\"\" style=\"position: absolute;cursor: pointer;\" current-action=\"edit\"/>\r\n    <table style=\"text-align: center;align-self: end;margin-bottom: 30px;\">\r\n      <tr>\r\n        <td>\r\n          <p id=\"kbd-current-usb-client-firmware\" style=\"font-size: 14px;\"></p>\r\n        </td>\r\n      </tr>\r\n      <tr>\r\n        <td>\r\n          <p id=\"kbd-current-usb-client-firmware-new\" class=\"layui-firmware-new\" style=\"color: #16B777;\" firmware-action=\"click\" data-i18n-text=\"STRID_HOME_NEW_VER_AVAIL\">有新的版本可用</p>\r\n        </td>\r\n      </tr>\r\n    </table>\r\n  </div>\r\n</div>\r\n\r\n<div id=\"receiver-panel\" class=\"layui-receiver-panel layui-auto-zoom\">\r\n</div>\r\n\r\n<div id=\"setting-panel\" class=\"layui-setting-panel layui-auto-zoom layui-form\" style=\"margin-bottom: 39px;display: none;\">\r\n  <table id=\"settings\">\r\n    <tr>\r\n      <td style=\"vertical-align: top;height: 1px;\">\r\n        <div style=\"display: flex;height: 100%;min-height: 400px;\">\r\n          <div id=\"setting-mapping-section\" class=\"layui-setting-section\" style=\"width: 330px;\">\r\n            <img id=\"product-name\" src=\"\"/>\r\n            <p class=\"layui-setting-title\" style=\"font-size: large; margin-top: 10px;\" data-i18n-text=\"STRID_SETTING_MAPPING_TYPE\">映射类型</p>\r\n            <div id=\"tab-mapping-key-type\" class=\"layui-tab layui-tab-brief\" lay-filter=\"mapping-key-type\" style=\"margin-bottom: 0px;\">\r\n              <ul class=\"layui-tab-title\">\r\n                <li lay-id=\"0\" data-i18n-text=\"STRID_SETTING_MAPPING_TYPE_KEY\">按键</li>\r\n                <li lay-id=\"1\" data-i18n-text=\"STRID_SETTING_MAPPING_TYPE_MACRO\">宏</li>\r\n                <li lay-id=\"2\" data-i18n-text=\"STRID_SETTING_MAPPING_TYPE_FUNCTION\">功能</li>\r\n                <li lay-id=\"3\" class=\"layui-this\" data-i18n-text=\"STRID_NONE\">无</li>\r\n              </ul>\r\n              <div class=\"layui-tab-content\" style=\"padding-bottom: 0px;\">\r\n                <div class=\"layui-tab-item\">\r\n                  <div id=\"mapping-key-container\" class=\"key-shortcuts-table\" style=\"display: none;\" >\r\n                    <table style=\"width: 100%;\">\r\n                      <tr>\r\n                        <td style=\"width: 100%;\">\r\n                          <div class=\"layui-setting-title-container\">\r\n                            <div class=\"layui-setting-title-bar\"></div>\r\n                            <p class=\"layui-setting-title\" data-i18n-text=\"STRID_SETTING_MAPPING_SELECT_KEY\">选择按键</p>\r\n                          </div>\r\n                        </td>\r\n                        <td>\r\n                          <button id=\"mapping-key-record\" class=\"layui-btn layui-btn-radius layui-btn-sm\" style=\"background-color: #16B777;\" mapping-key-action=\"record\" data-i18n-text=\"STRID_SETTING_MAPPING_KEY_RECORD\">录制</button>\r\n                        </td>\r\n                      </tr>\r\n                    </table>\r\n                    <p class=\"layui-setting-title\" style=\"margin-left: 0px;margin-top: 12px;\" data-i18n-text=\"STRID_SETTING_MAPPING_CTRL_KEY\">控制键</p>\r\n                    <div style=\"margin-top: 4px;display: flex;\">\r\n                      <div id=\"setting-mapping-ctrl-key1\" class=\"layui-input-inline\" style=\"width: 50%;\"></div>\r\n                      <div id=\"setting-mapping-ctrl-key2\" class=\"layui-input-inline\" style=\"width: 50%;margin-left: 12px;\"></div>\r\n                    </div>\r\n                    <p class=\"layui-setting-title\" style=\"margin-left: 0px;margin-top: 12px;\" data-i18n-text=\"STRID_SETTING_MAPPING_TYPE_KEY\">按键</p>\r\n                    <div style=\"margin-top: 4px;display: flex;\">\r\n                      <div id=\"setting-mapping-key\" class=\"layui-input-inline\" style=\"width: 100%;\"></div>\r\n                      <div id=\"wheel-delta-container\" style=\"width: 180px;display: none;\">\r\n                        <p class=\"layui-setting-desc\" style=\"margin-left: 4px;margin-right: 4px;\" data-i18n-text=\"STRID_SETTING_MAPPING_MACRO_ACTION_WHEEL_DELTA_S\">步长</p>\r\n                        <input id=\"wheel-delta-input\" class=\"layui-input\" type=\"number\" lay-affix=\"number\" lay-filter=\"wheel-delta-input\" style=\"width: 70px; margin: 0 auto; display: block;\" placeholder=\"\" step=\"1\" min=\"1\" max=\"64\" >\r\n                      </div>\r\n                    </div>\r\n                    <p id=\"keys-fw-channel-gaming-tips\" class=\"layui-setting-desc\" data-i18n-text=\"STRID_SETTING_FW_CHANNEL_GAME_ONLY_KEY_TIPS\" style=\"margin-top: 10px;color: #16B777;\"></p>\r\n                    <div id=\"mapping-key-turbo-container\" style=\"margin-top: 12px\">\r\n                      <input type=\"checkbox\" name=\"mapping-key-turbo\" value=\"1\" title=\"Turbo（单位：毫秒）\" lay-filter=\"mapping-key-turbo\" data-i18n-title=\"STRID_SETTING_MAPPING_KEY_TURBO\">\r\n                      <div id=\"mapping-key-turbo-detail-container\" style=\"margin-top: 12px\">\r\n                        <div style=\"width: 100%;display: flex;\">\r\n                          <div align-items=\"right\" style=\"width: 50%;display: flex;\">\r\n                            <div class=\"layui-setting-mapping-key-desc-right\" style=\"width: 100%;\">\r\n                              <p class=\"layui-setting-desc\" style=\"margin-right: 4px;\" data-i18n-text=\"STRID_SETTING_MAPPING_KEY_TURBO_FREQ\">每秒点击数</p>\r\n                            </div>\r\n                            <input id=\"mapping-key-turbo-freq-input\" class=\"layui-input\" type=\"number\" lay-affix=\"number\" lay-filter=\"mapping-key-turbo-freq-input\" style=\"width: 80px; margin: 0 auto; display: block;\" placeholder=\"\" step=\"1\" min=\"1\" max=\"1000\">\r\n                          </div>\r\n                          <div text-align=\"right\" style=\"width: 50%;display: flex;\">\r\n                            <div class=\"layui-setting-mapping-key-desc-right\" style=\"width: 100%;\">\r\n                              <p class=\"layui-setting-desc\" style=\"margin-right: 4px;\" data-i18n-text=\"STRID_SETTING_MAPPING_KEY_TURBO_RAND\">随机</p>\r\n                            </div>\r\n                            <input id=\"mapping-key-turbo-rand-input\" class=\"layui-input\" type=\"number\" lay-affix=\"number\" lay-filter=\"mapping-key-turbo-rand-input\" style=\"width: 70px; margin: 0 auto; display: block;\" placeholder=\"\" step=\"1\" min=\"0\">\r\n                          </div>\r\n                        </div>\r\n                        <div align-items=\"right\" style=\"width: 100%;margin-top: 12px;display: flex;\">\r\n                          <div align-items: right style=\"width: 50%;display: flex;\">\r\n                            <div class=\"layui-setting-mapping-key-desc-right\" style=\"width: 100%;\">\r\n                              <p class=\"layui-setting-desc\" style=\"margin-right: 4px;\" data-i18n-text=\"STRID_SETTING_MAPPING_KEY_TURBO_DOWN_KEEP\">按下保持</p>\r\n                            </div>\r\n                            <input id=\"mapping-key-turbo-down-keep-input\" class=\"layui-input\" type=\"number\" lay-affix=\"number\" lay-filter=\"mapping-key-turbo-down-keep-input\" style=\"width: 80px; margin: 0 auto; display: block;\" placeholder=\"\" step=\"1\" min=\"0\">\r\n                          </div>\r\n                          <div align-items=\"right\" style=\"width: 50%;display: flex;\">\r\n                            <div class=\"layui-setting-mapping-key-desc-right\" style=\"width: 100%;\">\r\n                              <p class=\"layui-setting-desc\" style=\"margin-right: 4px;\" data-i18n-text=\"STRID_SETTING_MAPPING_KEY_TURBO_UP_KEEP\">松开保持</p>\r\n                            </div>\r\n                            <input id=\"mapping-key-turbo-up-keep-input\" class=\"layui-input\" type=\"number\" lay-affix=\"number\" lay-filter=\"mapping-key-turbo-up-keep-input\" style=\"width: 70px; margin: 0 auto; display: block;\" placeholder=\"\" step=\"1\" min=\"0\">\r\n                          </div>\r\n                        </div>\r\n                      </div>\r\n                    </div>\r\n                    <div class=\"layui-setting-title-container\" style=\"margin-top: 16px; margin-bottom: 5px;\">\r\n                      <div class=\"layui-setting-title-bar\"></div>\r\n                      <p class=\"layui-setting-title\" data-i18n-text=\"STRID_SETTING_MAPPING_KEY_CMD\">指令</p>\r\n                    </div>\r\n                    <table id=\"key-shortcuts\" class=\"layui-hide\">\r\n                    </table>\r\n                  </div>\r\n                </div>\r\n                <div class=\"layui-tab-item\">\r\n                  <div id=\"mapping-macro-container\" style=\"display: none;\">\r\n                    <div style=\"display: flex;\">\r\n                      <div class=\"layui-setting-title-container\" style=\"width: 100%;\">\r\n                        <div class=\"layui-setting-title-bar\"></div>\r\n                        <p class=\"layui-setting-title\" data-i18n-text=\"STRID_SETTING_MAPPING_MACRO\">宏定义</p>\r\n                      </div>\r\n                      <button id=\"mapping-macro-edit\" class=\"layui-btn layui-btn-radius layui-btn-sm\" style=\"background-color: #16B777;\" mapping-macro-edit-action=\"edit\" data-i18n-text=\"STRID_EDIT\">编辑</button>\r\n                    </div>\r\n                    <div style=\"margin-top: 12px;\">\r\n                      <p class=\"layui-setting-title\" data-i18n-text=\"STRID_SETTING_MAPPING_MACRO_TRIGGER_TYPE\">触发方式：</p>\r\n                      <div id=\"setting-mapping-macro-trigger-type\" class=\"layui-input-inline\" style=\"width: 100%;margin-top: 4px;\"></div>\r\n                    </div>\r\n                    <div style=\"margin-top: 12px;\">\r\n                      <p class=\"layui-setting-title\" data-i18n-text=\"STRID_SETTING_MAPPING_TOGGLE_KEY2\">开关按键：</p>\r\n                      <div id=\"setting-mapping-macro-trigger-key\" class=\"layui-input-inline\" style=\"width: 100%;margin-top: 4px;\"></div>\r\n                    </div>\r\n                    <div style=\"margin-top: 12px;\">\r\n                      <p class=\"layui-setting-title\" data-i18n-text=\"STRID_SETTING_MAPPING_MACRO_STOP_KEY\">终止键：</p>\r\n                      <div id=\"setting-mapping-macro-stop-key\" class=\"layui-input-inline\" style=\"width: 100%;margin-top: 4px;\"></div>\r\n                    </div>\r\n                    <p id=\"setting-mapping-macro-actions\" class=\"layui-setting-title\" style=\"margin-top: 20px;\"></p>\r\n                  </div>\r\n                </div>\r\n                <div class=\"layui-tab-item\">\r\n                  <div id=\"mapping-function-container\" style=\"margin-top: 4px;display: none;\">\r\n                    <div class=\"layui-setting-title-container\">\r\n                      <div class=\"layui-setting-title-bar\"></div>\r\n                      <p class=\"layui-setting-title\" data-i18n-text=\"STRID_SETTING_MAPPING_TYPE_FUNCTION_SELECT\">选择功能</p>\r\n                    </div>\r\n                    <div id=\"mapping-function-select\" class=\"layui-input-inline\" style=\"width: 100%; margin-top:12px;\"></div>\r\n                    <div id=\"mapping-function-dpi-container\" style=\" margin-top: 10px;display: none;\">\r\n                      <p class=\"layui-setting-title\" style=\"margin-left: 0px;\"data-i18n-text=\"STRID_SETTING_DPI\">灵敏度（DPI）</p>\r\n                      <p class=\"layui-setting-desc\" data-i18n-text=\"STRID_SETTING_MAPPING_TYPE_FUNCTION_PRESS_CPI_SUMMARY\">按下按键切换至该DPI/CPI，松开后恢复</p>\r\n                      <div id=\"slider-function-dpi-input\" style=\"margin-top: 50px;margin-left: 10px;\"></div>\r\n                    </div> \r\n                    <div id=\"mapping-function-toggle-esb-container\" style=\"margin-top: 12px;display: none;\">\r\n                      <p class=\"layui-setting-desc\" data-i18n-text=\"STRID_SETTING_MAPPING_TYPE_FUNCTION_TOGGLE_ESB_ADDR_SUMMARY\"></p>\r\n                      <div id=\"paired-esb-addr-list\">\r\n                      </div>\r\n                    </div> \r\n                    <div id=\"mapping-function-toggle-ble-container\" style=\"margin-top: 12px;display: none;\">\r\n                      <p class=\"layui-setting-desc\" data-i18n-text=\"STRID_SETTING_MAPPING_TYPE_FUNCTION_TOGGLE_BLE_DEVICE_SUMMARY\"></p>\r\n                      <div id=\"paired-ble-addr-list\">\r\n                      </div>\r\n                    </div> \r\n                    <div id=\"mapping-function-show-power-container\" style=\"margin-top: 12px;display: none;\">\r\n                      <p class=\"layui-setting-desc\" data-i18n-text=\"STRID_SETTING_MAPPING_TYPE_FUNCTION_SHOW_POWER_SUMMARY\"></p>\r\n                    </div> \r\n                    <div id=\"mapping-function-shell-cmd-container\" class=\"layui-form-item\" style=\"margin-top: 12px;width: 100%;\">\r\n                      <table style=\"margin-bottom: 5px;\">\r\n                        <tr>\r\n                          <td>\r\n                            <input type=\"radio\" name=\"function-shell-cmd\" value=\"0\" title=\"程序\" data-i18n-title=\"STRID_SETTING_MAPPING_TYPE_FUNCTION_SHELL_CMD_APP\" lay-filter=\"function-shell-cmd\">\r\n                          </td>\r\n                          <td>\r\n                            <input type=\"radio\" name=\"function-shell-cmd\" value=\"1\" title=\"网站\" data-i18n-title=\"STRID_SETTING_MAPPING_TYPE_FUNCTION_SHELL_CMD_WEB\" lay-filter=\"function-shell-cmd\">\r\n                          </td>\r\n                        </tr>\r\n                      </table>\r\n                      <div id=\"function-shell-cmd-app-container\" style=\"display: flex;\">\r\n                        <div class=\"layui-form\" style=\"width: 100%;\">\r\n                          <input type=\"text\" id=\"function-shell-cmd-app\" name=\"function-shell-cmd-app\" placeholder=\"\" class=\"layui-input\" lay-filter=\"function-shell-cmd-app\">\r\n                        </div>\r\n                        <img id=\"function-shell-cmd-app-browse\" src=\"\" style=\"width: 27px;height: 24px; margin: 6px; cursor: pointer;display: none;\" shell-cmd-app-browse-action=\"edit\"/>\r\n                        <input type=\"file\" id=\"shell-cmd-app-browse_file\" name=\"file\" style=\"display: none\" onChange=\"shell_cmd_app_browse_file()\">\r\n                      </div>\r\n                      <div id=\"function-shell-cmd-web-container\" style=\"display: flex;\">\r\n                        <div class=\"layui-form\" style=\"width: 100%;\">\r\n                          <input type=\"text\" id=\"function-shell-cmd-web\"  name=\"function-shell-cmd-web\" placeholder=\"\" class=\"layui-input\" lay-filter=\"function-shell-cmd-web\">\r\n                        </div>\r\n                      </div>\r\n                      <p class=\"layui-setting-desc\" data-i18n-text=\"STRID_WEBHUB_APP_ONLY\" style=\"margin-top: 10px;color: #16B777;\"></p>\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n                <div class=\"layui-tab-item layui-show\">\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div style=\"text-align: center; padding-bottom: 5px; margin-left: auto; margin-right: auto;\">\r\n            <table>\r\n              <tr>\r\n                <td>\r\n                  <div id=\"setting_mapping_product_icon\" class=\"layui-product-icon-panel\" style=\"background-position: 0px 60px;\">\r\n                    <div class=\"layui-setting-title-container\" style=\"margin-top: 20px;\">\r\n                      <table style=\"margin: 0 auto;\">\r\n                        <tr>\r\n                          <td>\r\n                            <p class=\"layui-setting-title\" data-i18n-text=\"STRID_SETTING_CONFIG_CURRENT\">板载配置</p>\r\n                          </td>\r\n                          <td>\r\n                            <div id=\"setting-onboard-config\" class=\"layui-input-inline\" style=\"width: 180px;margin-left: 6px;\"></div>\r\n                          </td>\r\n                          <td>\r\n                            <i id=\"onboard-config-loading\" class=\"layui-icon layui-icon-loading layui-anim layui-anim-rotate layui-anim-loop\" style=\"font-size: 20px; color: #1E9FFF;margin-left: 5px;display: none;\"></i>\r\n                          </td>\r\n                        </tr>\r\n                      </table>\r\n                    </div>\r\n                    <div class=\"layui-setting-title-container\" style=\"margin-top: 20px;\">\r\n                      <table style=\"margin: 0 auto;\">\r\n                        <tr>\r\n                          <td>\r\n                            <p class=\"layui-setting-title\" data-i18n-text=\"STRID_SETTINGD_KEY_COMBINATION_LABEL\">R-Plus 键</p>\r\n                          </td>\r\n                          <td>\r\n                            <div id=\"setting-combination-key\" class=\"layui-input-inline\" style=\"width: 150px;margin-left: 6px;\"></div>\r\n                          </td>\r\n                        </tr>\r\n                      </table>\r\n                    </div>\r\n                    <p class=\"layui-setting-desc\" data-i18n-text=\"STRID_SETTINGD_KEY_COMBINATION_DESC\">按住 R-Plus 键的同时再按下其他按键，可以触发第二层映射功能</p>\r\n                    <div style=\"position: absolute;\">\r\n                      <div id=\"setting-mapping-key-m1\" style=\"position: absolute;height: 50px; left: 30px; top: 90px;\">\r\n                        <div class=\"layui-setting-title-container\">\r\n                          <p id=\"setting-mapping-key-m1-text\" class=\"layui-setting-mapping-key-name\" style=\"margin-top: 18px;\">①</p>\r\n                          <div mapping-action=\"setting-mapping-key\" value=\"setting_mapping_key_m1\" style=\"cursor: pointer;\">\r\n                            <div class=\"layui-setting-mapping-key-desc-left\" style=\"padding-top: 5px;\">\r\n                              <p id=\"setting-mapping-key-m1-desc\" class=\"layui-setting-desc layui-outline\" style=\"margin: 4px;line-height: 1.3em;\"></p>\r\n                            </div>\r\n                            <div id=\"setting-mapping-key-m1-line\" style=\"width: 210px;height: 1px; background-color: gray;margin-bottom: 4px;\"></div>\r\n                          </div>\r\n                          <img id=\"setting-mapping-key-m1-circle\" src=\"\"  style=\"margin-top: 22px;\"/>\r\n                        </div>\r\n                      </div>\r\n                      <div id=\"setting-mapping-key-m6\" style=\"position: absolute;height: 50px; left: 30px; top: 180px;\">\r\n                        <div class=\"layui-setting-title-container\">\r\n                          <p id=\"setting-mapping-key-m6-text\" class=\"layui-setting-mapping-key-name\" style=\"margin-top: 18px;\">⑥</p>\r\n                          <div mapping-action=\"setting-mapping-key\" value=\"setting_mapping_key_m6\" style=\"cursor: pointer;\">\r\n                            <div class=\"layui-setting-mapping-key-desc-left\" style=\"padding-top: 5px;\">\r\n                              <p id=\"setting-mapping-key-m6-desc\" class=\"layui-setting-desc layui-outline\" style=\"margin: 4px;line-height: 1.3em;\"></p>\r\n                            </div>\r\n                            <div id=\"setting-mapping-key-m6-line\" style=\"width: 175px;height: 1px; background-color: gray;margin-bottom: 4px;\"></div>\r\n                          </div>\r\n                          <img id=\"setting-mapping-key-m6-circle\" src=\"\"  style=\"margin-top: 22px;\"/>\r\n                        </div>\r\n                      </div>\r\n                      <div id=\"setting-mapping-key-m5\" style=\"position: absolute;height: 50px; left: 30px; top: 240px;\">\r\n                        <div class=\"layui-setting-title-container\">\r\n                          <p id=\"setting-mapping-key-m5-text\" class=\"layui-setting-mapping-key-name\" style=\"margin-top: 18px;\">⑤</p>\r\n                          <div mapping-action=\"setting-mapping-key\" value=\"setting_mapping_key_m5\" style=\"cursor: pointer;\">\r\n                            <div class=\"layui-setting-mapping-key-desc-left\" style=\"padding-top: 5px;\">\r\n                              <p id=\"setting-mapping-key-m5-desc\" class=\"layui-setting-desc layui-outline\" style=\"margin: 4px;line-height: 1.3em;\"></p>\r\n                            </div>\r\n                            <div id=\"setting-mapping-key-m5-line\" style=\"width: 180px;height: 1px; background-color: gray;margin-bottom: 4px;\"></div>\r\n                          </div>\r\n                          <img id=\"setting-mapping-key-m5-circle\" src=\"\"  style=\"margin-top: 22px;\"/>\r\n                        </div>\r\n                      </div>\r\n                      <div id=\"setting-mapping-key-m3\" style=\"position: absolute;height: 50px; left: 365px; top: 90px;\">\r\n                        <div class=\"layui-setting-title-container\">\r\n                          <img id=\"setting-mapping-key-m3-circle\" src=\"\" style=\"margin-top: 22px;\"/>\r\n                          <div mapping-action=\"setting-mapping-key\" value=\"setting_mapping_key_m3\" style=\"cursor: pointer;\">\r\n                            <div class=\"layui-setting-mapping-key-desc-right\" style=\"padding-top: 5px;\">\r\n                              <p id=\"setting-mapping-key-m3-desc\" class=\"layui-setting-desc layui-outline\" style=\"margin: 4px;line-height: 1.3em;\"></p>\r\n                            </div>\r\n                            <div id=\"setting-mapping-key-m3-line\" style=\"width: 197px;height: 1px; background-color: gray;margin-bottom: 4px;\"></div>\r\n                          </div>\r\n                          <p id=\"setting-mapping-key-m3-text\" class=\"layui-setting-mapping-key-name\" style=\"margin-top: 18px;\">③</p>\r\n                        </div>\r\n                      </div>\r\n                      <div id=\"setting-mapping-key-m2\" style=\"position: absolute;height: 50px; left: 315px; top: 122px;\">\r\n                        <div class=\"layui-setting-title-container\">\r\n                          <img id=\"setting-mapping-key-m2-circle\" src=\"\" style=\"margin-top: 22px;\"/>\r\n                          <div mapping-action=\"setting-mapping-key\" value=\"setting_mapping_key_m2\" style=\"cursor: pointer;\">\r\n                            <div class=\"layui-setting-mapping-key-desc-right\" style=\"padding-top: 5px;\">\r\n                              <p id=\"setting-mapping-key-m2-desc\" class=\"layui-setting-desc layui-outline\" style=\"margin: 4px;line-height: 1.3em;\"></p>\r\n                            </div>\r\n                            <div id=\"setting-mapping-key-m2-line\" style=\"width: 247px;height: 1px; background-color: gray;margin-bottom: 4px;\"></div>\r\n                          </div>\r\n                          <p id=\"setting-mapping-key-m2-text\" class=\"layui-setting-mapping-key-name\" style=\"margin-top: 18px;\">②</p>\r\n                        </div>\r\n                      </div>\r\n                      <div id=\"setting-mapping-key-m4\" style=\"position: absolute;height: 50px; left: 315px; top: 190px;\">\r\n                        <div class=\"layui-setting-title-container\">\r\n                          <img id=\"setting-mapping-key-m4-circle\" src=\"\" style=\"margin-top: 22px;\"/>\r\n                          <div mapping-action=\"setting-mapping-key\" value=\"setting_mapping_key_m4\" style=\"cursor: pointer;\">\r\n                            <div class=\"layui-setting-mapping-key-desc-right\" style=\"padding-top: 5px;\">\r\n                              <p id=\"setting-mapping-key-m4-desc\" class=\"layui-setting-desc layui-outline\" style=\"margin: 4px;line-height: 1.3em;\"></p>\r\n                            </div>\r\n                            <div id=\"setting-mapping-key-m4-line\" style=\"width: 247px;height: 1px; background-color: gray;margin-bottom: 4px;\"></div>\r\n                          </div>\r\n                          <p id=\"setting-mapping-key-m4-text\" class=\"layui-setting-mapping-key-name\" style=\"margin-top: 18px;\">④</p>\r\n                        </div>\r\n                      </div>\r\n                      <div id=\"setting-mapping-key-m7\" style=\"position: absolute;height: 50px; left: 315px; top: 302px;\">\r\n                        <div class=\"layui-setting-title-container\">\r\n                          <img id=\"setting-mapping-key-m7-circle\" src=\"\" style=\"margin-top: 22px;\"/>\r\n                          <div mapping-action=\"setting-mapping-key\" value=\"setting_mapping_key_m7\" style=\"cursor: pointer;\">\r\n                            <div class=\"layui-setting-mapping-key-desc-right\" style=\"padding-top: 5px;\">\r\n                              <p id=\"setting-mapping-key-m7-desc\" class=\"layui-setting-desc layui-outline\" style=\"margin: 4px;line-height: 1.3em;\"></p>\r\n                            </div>\r\n                            <div id=\"setting-mapping-key-m7-line\" style=\"width: 247px;height: 1px; background-color: gray;margin-bottom: 4px;\"></div>\r\n                          </div>\r\n                          <p id=\"setting-mapping-key-m7-text\" class=\"layui-setting-mapping-key-name\" style=\"margin-top: 18px;\">⑦</p>\r\n                        </div>\r\n                        <p class=\"layui-setting-title layui-outline\" style=\"margin-left: -270px;\" data-i18n-text=\"STRID_SETTING_MAPPING_BOTTOM_KEY\">底部</p>\r\n                      </div>\r\n                      <div id=\"setting-mapping-key-wheel-line-container\" style=\"position: absolute; left: 315px; top: 68px;\">\r\n                        <div id=\"setting-mapping-key-wheel-line\" style=\"width: 1px;height: 57px; margin-left: 10px; background-color: gray;\"></div>\r\n                        <img id=\"setting-mapping-key-wheel-circle\" src=\"\"/>\r\n                      </div>\r\n                      <div id=\"setting-mapping-key-wheel-down\" style=\"position: absolute;height: 50px; left: 80px; top: 32px;\">\r\n                        <div class=\"layui-setting-title-container\">\r\n                          <p id=\"setting-mapping-key-wheel-down-text\" class=\"layui-setting-mapping-key-name\" style=\"margin-top: 18px;\">▼</p>\r\n                          <div mapping-action=\"setting-mapping-key\" value=\"setting_mapping_key_wheel_down\" style=\"cursor: pointer;\">\r\n                            <div class=\"layui-setting-mapping-key-desc-left\" style=\"padding-top: 5px;\">\r\n                              <p id=\"setting-mapping-key-wheel-down-desc\" class=\"layui-setting-desc layui-outline\" style=\"margin: 4px;line-height: 1.3em;\"></p>\r\n                            </div>\r\n                            <div id=\"setting-mapping-key-wheel-down-line\" style=\"width: 221px;height: 1px; background-color: gray;margin-bottom: 4px;\"></div>\r\n                          </div>\r\n                        </div>\r\n                      </div>\r\n                      <div id=\"setting-mapping-key-wheel-up\" style=\"position: absolute;height: 50px; left: 325px; top: 32px;\">\r\n                        <div class=\"layui-setting-title-container\">\r\n                          <div mapping-action=\"setting-mapping-key\" value=\"setting_mapping_key_wheel_up\" style=\"cursor: pointer;\">\r\n                            <div class=\"layui-setting-mapping-key-desc-right\" style=\"padding-top: 5px;\">\r\n                              <p id=\"setting-mapping-key-wheel-up-desc\" class=\"layui-setting-desc layui-outline\" style=\"margin: 4px;line-height: 1.3em;\"></p>\r\n                            </div>\r\n                            <div id=\"setting-mapping-key-wheel-up-line\" style=\"width: 221px;height: 1px; background-color: gray;margin-bottom: 4px;\"></div>\r\n                          </div>\r\n                          <p id=\"setting-mapping-key-wheel-up-text\" class=\"layui-setting-mapping-key-name\" style=\"margin-top: 18px;\">▲</p>\r\n                        </div>\r\n                      </div>\r\n                    </div>\r\n                    <div id=\"setting-onboard_status\" style=\"margin-top:440px;\">\r\n                      <table style=\"margin: 0 auto;\">\r\n                        <tr>\r\n                          <td style=\"font-size: medium; white-space: nowrap;vertical-align: middle;padding-right: 6px;\" data-i18n-text=\"STRID_SETTING_CONFIG_CURRENT_ALLOW_SWITCH\">\r\n                            允许切换\r\n                          </td>\r\n                          <td style=\"padding-bottom: 8px;\">\r\n                            <input type=\"checkbox\" name=\"onboard-allow-switch\" value=\"1\" lay-skin=\"switch\" lay-filter=\"onboard-allow-switch\">\r\n                          </td>\r\n                          <td style=\"font-size: medium; white-space: nowrap;vertical-align: middle;padding-right: 6px;padding-left: 20px;\" data-i18n-text=\"STRID_SETTING_LIGHT\">\r\n                            灯效\r\n                          </td>\r\n                          <td style=\"padding-top: 6px;\">\r\n                            <div id=\"setting-onboard-status-colors\" style=\"margin-top: 6px;margin-bottom: 6px;text-align: center;width: fit-content\">\r\n                            </div>\r\n                          </td>\r\n                        </tr>\r\n                      </table>\r\n                    </div>\r\n                  </div>\r\n                </td>\r\n              </tr>\r\n              <tr style=\"width: 100%\">\r\n                <td>\r\n                  <div class=\"layui-row\">\r\n                    <div class=\"layui-col-xs6\">\r\n                      <button id=\"factory-reset\" class=\"layui-btn layui-btn-radius layui-bg-blue layui-btn-lg\" factory-reset-action=\"apply\" data-i18n-text=\"STRID_SETTING_FACTORY_RESET\">恢复出厂设置</button>\r\n                    </div>\r\n                    <div class=\"layui-col-xs6\">\r\n                      <button id=\"mapping-apply-and-onboard\" class=\"layui-btn layui-btn-radius layui-bg-blue layui-btn-lg\" mapping-apply-and-onboard-action=\"apply\" data-i18n-text=\"STRID_SETTING_MAPPING_APPLY_AND_ONBOARD\">应用&写入</button>\r\n                    </div>\r\n                  </div>\r\n                </td>\r\n              </tr>\r\n            </table>\r\n          </div>\r\n        </div>\r\n      </td>\r\n      <td style=\"width: 35%;min-width: 340px;vertical-align: top;padding-right: 30px;\">\r\n        <!--DPI速度-->\r\n        <div id=\"setting-dpi-section\" class=\"layui-setting-section\">\r\n          <div class=\"layui-setting-title-container\">\r\n            <div class=\"layui-setting-title-bar\"></div>\r\n            <p class=\"layui-setting-title\" data-i18n-text=\"STRID_SETTING_DPI_SPEED\">DPI速度</p>\r\n          </div>\r\n          <p class=\"layui-setting-desc\" data-i18n-text=\"STRID_SETTING_DPI_SPEED_DESC\">鼠标移动每英寸的点数（DPI/CPI），您可以在编辑模式下点击档位来修改/删除数值。</p>\r\n          <div id=\"dpi-both-x-y\" style=\"margin-top: 15px;\">\r\n            <input type=\"checkbox\" name=\"dpi-both-x-y\" value=\"1\" title=\"分别设置 X 和 Y 数值\" lay-filter=\"dpi-both-x-y\" data-i18n-title=\"STRID_SETTING_DPI_BOTH_X_Y\">\r\n          </div>\r\n          <div style=\"margin-top: 25px;\">\r\n            <span id=\"slider-dpi-x-input-label\" style=\"position: fixed; margin-top: -6px;\">X</span>\r\n            <div id=\"slider-dpi-x-input\" style=\"margin-left: 18px;\"></div>\r\n          </div>\r\n          <div id=\"slider-dpi-y-input-container\" style=\"margin-top: 40px;\">\r\n            <span id=\"slider-dpi-y-input-label\" style=\"position: fixed; margin-top: -6px;\">Y</span>\r\n            <div id=\"slider-dpi-y-input\" style=\"margin-left: 18px;\"></div>\r\n          </div>\r\n          <div class=\"layui-setting-title-container\" style=\"margin-top: 25px\">\r\n            <p data-i18n-text=\"STRID_SETTING_DPI_LEVEL\">档位</p>\r\n            <button id=\"dpi-level-edit\" class=\"layui-btn layui-btn-radius layui-btn-sm\" style=\"margin-left: 20px;background-color: #16B777;\" dpi-level-edit-action=\"edit\" data-i18n-text=\"STRID_EDIT\">编辑</button>\r\n            <button id=\"dpi-level-add\" class=\"layui-btn layui-btn-radius layui-btn-sm\"  style=\"background-color: #16B777;\" dpi-level-add-action=\"edit\" data-i18n-text=\"STRID_SETTING_DPI_LEVEL_ADD\">添加</button>\r\n          </div>\r\n          <div id=\"setting-dpi-levels\" style=\"text-align: center;width: fit-content;\">\r\n          </div>\r\n        </div>\r\n        <!--轮询率-->\r\n        <div id=\"setting-polling-rate-section\" class=\"layui-setting-section\" style=\"margin-top: 10px\">\r\n          <table style=\"width: 100%;\">\r\n            <tr>\r\n              <td>\r\n                <div class=\"layui-setting-title-container\">\r\n                  <div class=\"layui-setting-title-bar\"></div>\r\n                  <p class=\"layui-setting-title\" data-i18n-text=\"STRID_SETTING_POLLING_RATE\">轮询率（每秒）</p>\r\n                </div>\r\n              </td>\r\n              <td style=\"width: 100%;text-align: center;\">\r\n                <p id=\"glass-mode-activated\" style=\"color: #1E9FFF;\" data-i18n-text=\"STRID_SETTING_POLLING_RATE_GLASS_MODE\">玻璃表面模式已激活</p>\r\n              </td>\r\n              <td>\r\n                <div id=\"x-polling\">\r\n                  <label class=\"layui-form-label\" data-i18n-text=\"STRID_SETTING_STEPLESS_MODE\">X-Polling</label>\r\n                  <div class=\"layui-input-block\">\r\n                    <input type=\"checkbox\" name=\"x-polling\" value=\"1\" lay-skin=\"switch\" lay-filter=\"x-polling\">\r\n                  </div>\r\n                </div>\r\n              </td>\r\n            </tr>\r\n            <tr>\r\n              <td colspan=\"3\">\r\n                <p class=\"layui-setting-desc\" data-i18n-text=\"STRID_SETTING_POLLING_RATE_DESC\">或称回报率，鼠标的数据更新频率，修改后需重启鼠标才能生效。</p>\r\n              </td>\r\n            </tr>\r\n          </table>\r\n          <div id=\"setting-polling-rates\" class=\"layui-form-item\" style=\"margin-top: 8px;margin-bottom: 0px;\">\r\n          </div>\r\n          <div id=\"slider-x-polling-input\" style=\"margin-top: 30px; margin-bottom: 15px; display: none\">\r\n          </div>\r\n        </div>\r\n        <!--灯效-->\r\n        <div id=\"setting-light-section\" class=\"layui-setting-section\" style=\"margin-top: 10px\">\r\n          <div class=\"layui-setting-title-container\">\r\n            <div class=\"layui-setting-title-bar\"></div>\r\n            <p class=\"layui-setting-title\" data-i18n-text=\"STRID_SETTING_LIGHT\">灯效</p>\r\n            <div id=\"light\" style=\"margin-left: 30px;\">\r\n              <input type=\"checkbox\" name=\"light-auto-off\" value=\"1\" title=\"空闲时自动关闭\" lay-filter=\"light-auto-off\" data-i18n-title=\"STRID_SETTING_LIGHT_AUTO_OFF\">\r\n            </div>\r\n            <div id=\"brightness\" style=\"width: 100%;\">\r\n              <div class=\"layui-input-group\" style=\"float: right;\">\r\n                <div class=\"layui-input-prefix\" style=\"white-space: nowrap\" data-i18n-text=\"STRID_SETTING_LIGHT_BRIGHTNESS\">\r\n                  亮度\r\n                </div>\r\n                <div id=\"slider-brightness\" style=\"width: 255px;\"></div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div class=\"layui-form-item layui-row\" style=\"margin-top: 8px;margin-bottom: 0px;\">\r\n            <div class=\"layui-col-xs4\">\r\n              <input type=\"radio\" name=\"light-mode\" value=\"1\" title=\"循环\" data-i18n-title=\"STRID_SETTING_LIGHT_LOOP\" lay-filter=\"light-mode\">\r\n            </div>\r\n            <div class=\"layui-col-xs4\">\r\n              <input type=\"radio\" name=\"light-mode\" value=\"2\" title=\"自定义\" data-i18n-title=\"STRID_SETTING_LIGHT_DEFINE\" lay-filter=\"light-mode\"> \r\n            </div>\r\n            <div class=\"layui-col-xs4\">\r\n              <input type=\"radio\" name=\"light-mode\" value=\"3\" title=\"DPI档位\" data-i18n-title=\"STRID_SETTING_LIGHT_MODE\" lay-filter=\"light-mode\"> \r\n            </div>\r\n          </div>\r\n          <table id=\"setting-light-define-section\">\r\n            <tr>\r\n              <td style=\"width: 33%;\"></td>\r\n              <td style=\"text-align: center;\">\r\n                <i class=\"layui-setting-light-define-section-arrow\" style=\"position: absolute;margin-top: -5px;\">▲</i>\r\n                <div class=\"layui-setting-light-define-section\" style=\"width: fit-content;height: 30px;margin-top: 13px;\">\r\n                  <div id=\"setting-light-define-colors\" style=\"margin-top: 5px;margin-bottom: 10px;text-align: center;width: fit-content\">\r\n                  </div>\r\n                </div>\r\n              </td>\r\n              <td style=\"width: 66%;\"></td>\r\n            </tr>\r\n          </table>\r\n        </div>\r\n        <!--性能模式-->\r\n        <div id=\"setting-power-mode-section\" class=\"layui-setting-section\" style=\"margin-top: 10px\">\r\n          <table style=\"width: 100%;\">\r\n            <tr>\r\n              <td>\r\n                <div class=\"layui-setting-title-container\">\r\n                  <div class=\"layui-setting-title-bar\"></div>\r\n                  <p class=\"layui-setting-title\" data-i18n-text=\"STRID_SETTING_POWER_MODE\">性能模式</p>\r\n                </div>\r\n              </td>\r\n              <td style=\"width: 100%; text-align: end;\"><p id=\"surface-quality2\" style=\"color: #16B777;margin-left: 10px;display: none;\">鼠标垫性能:</p></td>\r\n              <td>\r\n                <div id=\"setting-glass-mode\" style=\"margin-right: -15px;\">\r\n                  <input type=\"checkbox\" name=\"glass-mode\" value=\"0\" title=\"玻璃模式\" lay-filter=\"glass-mode\" data-i18n-title=\"STRID_SETTING_POLLING_RATE_ENABLE_GLASS_MODE\">\r\n                </div>\r\n              </td>\r\n            </tr>\r\n            <tr>\r\n              <td colspan=\"3\">\r\n                <p id=\"selected-power-mode-tips\" style=\"color: #1E9FFF;margin-top: 5px;\"></p>\r\n              </td>\r\n            </tr>\r\n          </table>\r\n          <table style=\"margin-top: 8px;margin-bottom: 0px;width: 100%;\">\r\n            <tr>\r\n              <td>\r\n                <div id=\"setting-power-modes\"></div>\r\n              </td>\r\n            </tr>\r\n          </table>\r\n        </div>\r\n        <!--静默高度-->\r\n        <div id=\"setting-lod-section\" class=\"layui-setting-section\" style=\"margin-top: 10px\">\r\n          <div class=\"layui-setting-title-container\">\r\n            <div class=\"layui-setting-title-bar\"></div>\r\n            <p class=\"layui-setting-title\" data-i18n-text=\"STRID_SETTING_HAND_LIFT_DISTANCE\">静默高度（LOD）</p>\r\n            <p id=\"surface-quality\" style=\"color: #16B777;margin-left: 10px;display: none;\">鼠标垫性能:</p>\r\n          </div>\r\n          <p class=\"layui-setting-desc\" data-i18n-text=\"STRID_SETTING_HAND_LIFT_DISTANCE_TIPS\">鼠标抬起使指针失去响应的最小高度。</p>\r\n          <div id=\"setting-lods\" class=\"layui-form-item\" style=\"margin-top: 8px;margin-bottom: 0px;\">\r\n          </div>\r\n        </div>\r\n      </td>\r\n      <td style=\"width: 35%;min-width: 300px;vertical-align: top;padding-right: 30px;\">\r\n        <!--其他设置-->\r\n        <div id=\"setting-other-section\" class=\"layui-setting-section\">\r\n          <table style=\"width: 100%;\">\r\n            <tr>\r\n              <td style=\"width: 100%;\">\r\n                <div class=\"layui-setting-title-container\">\r\n                  <div class=\"layui-setting-title-bar\"></div>\r\n                  <p class=\"layui-setting-title\" data-i18n-text=\"STRID_SETTING_ANGLE_SNAPPING\">直线修正</p>\r\n                </div>\r\n              </td>\r\n              <td>\r\n                <div class=\"layui-input-block\">\r\n                  <input type=\"checkbox\" name=\"setting-angle-snapping\" value=\"1\" lay-skin=\"switch\" lay-filter=\"setting-angle-snapping\">\r\n                </div>\r\n              </td>\r\n            </tr>\r\n          </table>\r\n          <p class=\"layui-setting-desc\" data-i18n-text=\"STRID_SETTING_ANGLE_SNAPPING_TIPS\">修正鼠标移动时指针的偏移抖动。</p>\r\n          <hr class=\"layui-bg-gray\">\r\n          <table style=\"width: 100%;\">\r\n            <tr>\r\n              <td style=\"width: 100%;\">\r\n                <div class=\"layui-setting-title-container\">\r\n                  <div class=\"layui-setting-title-bar\"></div>\r\n                  <p class=\"layui-setting-title\" data-i18n-text=\"STRID_SETTING_RIPPLE_CONTROL\">波纹控制</p>\r\n                </div>\r\n              </td>\r\n              <td>\r\n                <div class=\"layui-input-block\">\r\n                  <input type=\"checkbox\" name=\"setting-ripple-control\" value=\"1\" lay-skin=\"switch\" lay-filter=\"setting-ripple-control\">\r\n                </div>\r\n              </td>\r\n            </tr>\r\n          </table>\r\n          <p class=\"layui-setting-desc\" data-i18n-text=\"STRID_SETTING_RIPPLE_CONTROL_TIPS\">消除鼠标高速移动情况下指针的波浪形抖动。</p>\r\n          <hr class=\"layui-bg-gray\">\r\n          <table style=\"width: 100%;\">\r\n            <tr>\r\n              <td style=\"width: 100%;\">\r\n                <div class=\"layui-setting-title-container\">\r\n                  <div class=\"layui-setting-title-bar\"></div>\r\n                  <p class=\"layui-setting-title\" data-i18n-text=\"STRID_SETTING_MOTION_SYNC\">移动同步</p>\r\n                </div>\r\n              </td>\r\n              <td>\r\n                <div class=\"layui-input-block\">\r\n                  <input type=\"checkbox\" name=\"setting-motion-sync\" value=\"1\" lay-skin=\"switch\" lay-filter=\"setting-motion-sync\">\r\n                </div>\r\n              </td>\r\n            </tr>\r\n          </table>\r\n          <p class=\"layui-setting-desc\" data-i18n-text=\"STRID_SETTING_MOTION_SYNC_TIPS\">使指针和鼠标移动更加同步，移动轨迹更准确。</p>\r\n          <hr class=\"layui-bg-gray\">\r\n          <table style=\"width: 100%;\">\r\n            <tr>\r\n              <td style=\"width: 100%;\">\r\n                <div class=\"layui-setting-title-container\">\r\n                  <div class=\"layui-setting-title-bar\"></div>\r\n                  <p class=\"layui-setting-title\" data-i18n-text=\"STRID_SETTING_WIRELESS_TURBO\">无线Turbo</p>\r\n                  <button id=\"btn-wireless-optimize\" class=\"layui-btn layui-btn-radius layui-btn-sm\" style=\"margin-left: 10px;background-color: #16B777;\" data-i18n-text=\"STRID_SETTING_FACTORY_TEST\" wireless-optimize-action=\"click\">无线优化</button>\r\n                  <p id=\"wireless-quality\" style=\"white-space: nowrap;color: #16B777;margin-left: 10px;width: 1px;\">无线质量:</p>\r\n                </div>\r\n              </td>\r\n              <td>\r\n                <div class=\"layui-input-block\">\r\n                  <input type=\"checkbox\" name=\"setting-wireless-turbo\" value=\"1\" lay-skin=\"switch\" lay-filter=\"setting-wireless-turbo\">\r\n                </div>\r\n              </td>\r\n            </tr>\r\n          </table>\r\n          <table>\r\n            <tr>\r\n              <td>\r\n                <p id=\"setting-wireless-turbo-desc\" class=\"layui-setting-desc\" data-i18n-text=\"STRID_SETTING_WIRELESS_TURBO_TIPS\">提升远距离和强干扰环境下的无线性能，但会增加功耗；可以尝试不同的模式，以获得最好的效果。</p>\r\n              </td>\r\n            </tr>\r\n            <tr>\r\n              <td>\r\n                <p id=\"selected-rf-channel-tips\" style=\"color: #1E9FFF;margin-top: 5px;\"></p>\r\n              </td>\r\n            </tr>\r\n          </table>\r\n          <div id=\"setting-rf-channels\" class=\"layui-form-item layui-row\" style=\"margin-bottom: 0px;\">\r\n            <table style=\"width: 100%;\">\r\n              <tr>\r\n                <td>\r\n                  <div class=\"layui-col-xs3\">\r\n                    <input type=\"radio\" name=\"setting-rf-channel\" value=\"2\" title=\"模式 1\" data-i18n-title=\"STRID_SETTING_RF_CHANNEL_2\" lay-filter=\"setting-rf-channel\">\r\n                  </div>\r\n                  <div class=\"layui-col-xs3\">\r\n                    <input type=\"radio\" name=\"setting-rf-channel\" value=\"40\" title=\"模式 2\" data-i18n-title=\"STRID_SETTING_RF_CHANNEL_40\" lay-filter=\"setting-rf-channel\">\r\n                  </div>\r\n                  <div class=\"layui-col-xs3\">\r\n                    <input type=\"radio\" name=\"setting-rf-channel\" value=\"80\" title=\"模式 3\" data-i18n-title=\"STRID_SETTING_RF_CHANNEL_80\" lay-filter=\"setting-rf-channel\">\r\n                  </div>\r\n                  <div id=\"setting-rf-channel-auto\" class=\"layui-col-xs3\">\r\n                    <input type=\"radio\" name=\"setting-rf-channel\" value=\"-1\" title=\"自动\" data-i18n-title=\"STRID_SETTING_RF_CHANNEL_AUTO\" lay-filter=\"setting-rf-channel\">\r\n                  </div>\r\n                </td>\r\n                <td>\r\n                  <div id=\"setting-power-saving\" style=\"padding-top: 2px;\">\r\n                    <input type=\"checkbox\" name=\"power-saving\" title=\"智能省电\" lay-filter=\"power-saving\" data-i18n-title=\"STRID_SETTING_MOUSE_AUTO_POWER_SAVING\">\r\n                  </div>\r\n                </td>\r\n              </tr>\r\n            </table>\r\n          </div>\r\n        </div>\r\n        <!--休眠时间-->\r\n        <div id=\"setting-sleep-time-section\" class=\"layui-setting-section\" style=\"margin-top: 10px\">\r\n          <div class=\"layui-setting-title-container\">\r\n            <div class=\"layui-setting-title-bar\"></div>\r\n            <p class=\"layui-setting-title\" data-i18n-text=\"STRID_SETTING_SLEEP_TIME\">休眠时间</p>\r\n          </div>\r\n          <p class=\"layui-setting-desc\" data-i18n-text=\"STRID_SETTING_SLEEP_TIME_TIPS\">鼠标静置该时间后，进入休眠状态，以降低功耗。</p>\r\n          <div id=\"slider-sleep-time\" style=\"margin-top: 50px; margin-bottom: 10px;\">\r\n          </div>\r\n        </div>\r\n        <!--角度修正-->\r\n        <div id=\"setting-angle-tuning-section\" class=\"layui-setting-section\" style=\"margin-top: 10px\">\r\n          <div class=\"layui-setting-title-container\">\r\n            <div class=\"layui-setting-title-bar\"></div>\r\n            <p class=\"layui-setting-title\" data-i18n-text=\"STRID_SETTING_ANGLE_TUNING\">角度修正</p>\r\n          </div>\r\n          <p class=\"layui-setting-desc\" data-i18n-text=\"STRID_SETTING_ANGLE_TUNING_TIPS\">鼠标移动时，其水平移动方向与指针水平移动方向之间的夹角。</p>\r\n          <div id=\"slider-angle-tuning\" style=\"margin-top: 30px; margin-bottom: 15px;\">\r\n          </div>\r\n        </div>\r\n        <!--按键响应-->\r\n        <div id=\"setting-key-delay-section\" class=\"layui-setting-section\" style=\"margin-top: 10px\">\r\n          <table style=\"width: 100%;\">\r\n            <tr>\r\n              <td>\r\n                <div class=\"layui-setting-title-container\">\r\n                  <div class=\"layui-setting-title-bar\"></div>\r\n                  <p class=\"layui-setting-title\" data-i18n-text=\"STRID_SETTING_KEY_RESPONSE\">按键响应</p>\r\n                </div>\r\n              </td>\r\n              <td>\r\n                <table id=\"setting-key-delay-select-key-container\" style=\"display: none;\">\r\n                  <tr>\r\n                    <td>\r\n                      <p data-i18n-text=\"STRID_SETTING_MAPPING_SELECT_KEY\">选择按键</p>\r\n                    </td>\r\n                    <td>\r\n                      <div id=\"setting-key-delay-select-key\" class=\"layui-input-inline\" style=\"width: 120px;margin-left: 5px;\"></div>\r\n                    </td>\r\n                    <td>\r\n                      <button class=\"layui-btn layui-btn-radius layui-btn-sm\" style=\"margin-left: 10px;background-color: #16B777;\" data-i18n-text=\"STRID_SETTING_KEY_GUIDE\" key-delay-action=\"click\">键位说明</button>\r\n                    </td>\r\n                  </tr>\r\n                </table>\r\n              </td>\r\n            </tr>\r\n          </table>\r\n          <p class=\"layui-setting-desc\" data-i18n-text=\"STRID_SETTING_KEY_RESPONSE_TIPS\">适当增加按键响应时间可提高按键稳定性。</p>\r\n          <table style=\"width: 100%;\">\r\n            <tr>\r\n              <td>\r\n                <div id=\"slider-key-down-delay\" style=\"margin-top: 30px; margin-bottom: 15px;\">\r\n                </div>\r\n              </td>\r\n              <td>\r\n                <div id=\"slider-key-up-delay\" style=\"margin-top: 30px; margin-bottom: 15px;margin-left: 15px;display: none;\">\r\n                </div>\r\n              </td>\r\n            </tr>\r\n            <tr id=\"setting-key-delay-down-up\" style=\"display: none;\">\r\n              <td>\r\n                <p data-i18n-text=\"STRID_SETTING_KEY_RESPONSE_DOWN\" style=\"text-align: center;\">按下</p>\r\n              </td>\r\n              <td>\r\n                <p data-i18n-text=\"STRID_SETTING_KEY_RESPONSE_UP\" style=\"text-align: center;\">松开</p>\r\n              </td>\r\n            </tr>\r\n          </table>\r\n        </div>\r\n      </td>\r\n    </tr>\r\n  </table>\r\n</div>\r\n  \r\n<!--DPI等级输入框-->\r\n<div id=\"dpi-level-input-panel\" style=\"background-color: transparent;display: none;padding: 10px;\">\r\n    <table class=\"layui-form\" style=\"text-align: center;\">\r\n      <tr>\r\n        <td>\r\n          <button id=\"dpi-level-input-hint\" class=\"layui-setting-title\" style=\"background-color: transparent;border-color: transparent;\" data-i18n-text=\"STRID_SETTING_DPI_LEVEL_SPEED_INPUT\">请输入档位数值</button>\r\n        </td>\r\n      </tr>\r\n      <tr id=\"dpi-level-input-layout\">\r\n        <td style=\"padding-top: 10px;\">\r\n          <input id=\"dpi-level-input\" class=\"layui-input\" type=\"number\" style=\"margin: 0 auto; display: block;\" lay-affix=\"number\" placeholder=\"\" step=\"50\" min=\"50\" max=\"26000\" >\r\n        </td>\r\n      </tr>\r\n      <tr id=\"x-dpi-level-input-layout\">\r\n        <td style=\"padding-top: 10px;\">\r\n          <input id=\"x-dpi-level-input\" class=\"layui-input\" type=\"number\" style=\"margin: 0 auto; display: block;\" lay-affix=\"number\" placeholder=\"X\" step=\"50\" min=\"50\" max=\"26000\" >\r\n        </td>\r\n      </tr>\r\n      <tr id=\"y-dpi-level-input-layout\">\r\n        <td style=\"padding-top: 10px;\">\r\n          <input id=\"y-dpi-level-input\" class=\"layui-input\" type=\"number\" style=\"margin: 0 auto; display: block;\" lay-affix=\"number\" placeholder=\"Y\" step=\"50\" min=\"50\" max=\"26000\" >\r\n        </td>\r\n      </tr>\r\n      <tr>\r\n        <td>\r\n          <button class=\"layui-setting-title\" style=\"background-color: transparent;border-color: transparent;margin-top: 10px;\" data-i18n-text=\"STRID_SETTING_DPI_LEVEL_COLOR\">请选择档位颜色</button>\r\n        </td>\r\n      </tr>\r\n      <tr>\r\n        <td>\r\n          <div class=\"layui-setting-light-define-section\" style=\"width: fit-content;height: 20px; margin-top: 4px;\">\r\n            <div id=\"dpi-input-colors\" style=\"text-align: center;width: fit-content\">\r\n            </div>\r\n          </div>\r\n        </td>\r\n      </tr>\r\n    </table>\r\n</div>\r\n\r\n<div id=\"kbd-setting-panel\" class=\"layui-kbd-setting-panel layui-auto-zoom layui-form\" style=\"margin-bottom: 39px;display: none;\">\r\n  <div style=\"display: flex;width: 100%; min-height: 400px;\">\r\n    <div id=\"setting-mapping-section\" class=\"layui-setting-section\" style=\"width: 240px; min-height: 830px; margin-top: 20px;\">\r\n      <img id=\"kbd-product-name\" src=\"\" style=\"margin-top: 20px;\"/>\r\n      <div class=\"layui-kbd-setting\" style=\"display: flex;width: 180px; height: 40px; align-items: center;margin-left: 30px; margin-right: 30px; margin-top: 60px; cursor: pointer;\" index=\"0\" kbd-main-setting-action=\"select\">\r\n        <img id=\"kbd-main-setting-key-icon\" style=\"display: flex;width: 36px; height: 32px; margin-left: 30px;\" src=\"\" />\r\n        <p id=\"kbd-main-setting-key\" class=\"layui-setting-title\" style=\"font-size: large; color:#00f6ff; margin-left: 10px;\" data-i18n-text=\"STRID_KBD_KEY_SETTING\">按键设置</p>\r\n      </div>\r\n      <div class=\"layui-kbd-setting\" style=\"display: flex;width: 180px; height: 40px; align-items: center; margin-left: 30px; margin-right: 30px; margin-top: 40px; cursor: pointer;\"  index=\"1\" kbd-main-setting-action=\"select\">\r\n        <img id=\"kbd-main-setting-light-icon\" style=\"display: flex;width: 36px; height: 32px; margin-left: 30px;\" src=\"\" />\r\n        <p id=\"kbd-main-setting-light\" class=\"layui-setting-title\" style=\"font-size: large; margin-left: 10px;\" data-i18n-text=\"STRID_KBD_LIGHT_SETTING\">灯效配置</p>\r\n      </div>\r\n      <div class=\"layui-kbd-setting\" style=\"display: flex;width: 180px; height: 40px; align-items: center; margin-left: 30px; margin-right: 30px; margin-top: 40px; cursor: pointer;\" index=\"2\" kbd-main-setting-action=\"select\">\r\n        <img id=\"kbd-main-setting-axis-icon\" style=\"display: flex;width: 36px; height: 32px; margin-left: 30px;\" src=\"\" />\r\n        <p id=\"kbd-main-setting-axis\" class=\"layui-setting-title\" style=\"font-size: large; margin-left: 10px;\" data-i18n-text=\"STRID_KBD_AXIS_SETTING\">性能配置</p>\r\n      </div>\r\n      <div class=\"layui-kbd-setting\" style=\"display: flex;width: 180px; height: 40px; align-items: center; margin-left: 30px; margin-right: 30px; margin-top: 40px; cursor: pointer;\" index=\"3\" kbd-main-setting-action=\"select\">\r\n        <img id=\"kbd-main-setting-advance-key-icon\" style=\"display: flex;width: 36px; height: 32px; margin-left: 30px;\" src=\"\" />\r\n        <p id=\"kbd-main-setting-advance-key\" class=\"layui-setting-title\" style=\"font-size: large; margin-left: 10px;\" data-i18n-text=\"STRID_KBD_ADVANCE_KEY_SETTING\">高级键</p>\r\n      </div>\r\n      <div class=\"layui-kbd-setting\" style=\"display: flex;width: 180px; height: 40px; align-items: center; margin-left: 30px; margin-right: 30px; margin-top: 40px; cursor: pointer;\"  index=\"4\" kbd-main-setting-action=\"select\">\r\n        <img id=\"kbd-main-setting-more-icon\" style=\"display: flex;width: 36px; height: 32px; margin-left: 30px;\" src=\"\" />\r\n        <p id=\"kbd-main-setting-more\" class=\"layui-setting-title\" style=\"font-size: large; margin-left: 10px;\" data-i18n-text=\"STRID_KBD_MORE_SETTING\">更多设置</p>\r\n      </div>\r\n    </div>\r\n    <div id=\"tab-kbd-main-setting-type\" class=\"layui-tab layui-tab-brief\" lay-filter=\"kbd-main-setting-type\" style=\"margin-bottom: 0px;\">\r\n      <ul class=\"layui-tab-title\" style=\"display: none;\">\r\n        <li lay-id=\"0\"  data-i18n-text=\"STRID_KBD_KEY_SETTING\">按键设置</li>\r\n        <li lay-id=\"1\" data-i18n-text=\"STRID_KBD_LIGHT_SETTING\">灯效配置</li>\r\n        <li lay-id=\"2\" data-i18n-text=\"STRID_KBD_AXIS_SETTING\">性能配置</li>\r\n        <li lay-id=\"3\" data-i18n-text=\"STRID_KBD_ADVANCE_KEY_SETTING\">高级键</li>\r\n        <li lay-id=\"4\" data-i18n-text=\"STRID_KBD_MORE_SETTING\">更多设置</li>\r\n      </ul>\r\n      <div class=\"layui-tab-content\" style=\"margin-left: 20px;\">\r\n        <div class=\"layui-tab-item\">\r\n          <div id=\"kbd-main-setting-key-container\" class=\"key-shortcuts-table\" style=\"display: none;\" >\r\n            <table style=\"width: 100%; margin-bottom: 30px;\">\r\n              <tr>\r\n                <td style=\"width: 100%;min-width: 640px;\">\r\n                  <div style=\"display: flex;\" >\r\n                    <div style=\"margin-left: 40px;\">\r\n                      <div id=\"kbd-mapping-key-container\" style=\"text-align: center;width: 934px;height: 348px;\">\r\n                      </div>\r\n                    </div>\r\n\r\n                    <div class=\"layui-container layui-auto-zoom\" style=\"width: 20%; margin-left: 40px;\">\r\n                      <div id=\"kbd-key-layer-container\" style=\"margin-left: 20px; margin-top: 20px;\">\r\n                        <table>\r\n                          <tr>\r\n                            <td>\r\n                              <p class=\"layui-setting-title\" data-i18n-text=\"STRID_KBD_KEY_LAYER\">按键层</p>\r\n                            </td>\r\n                            <td>\r\n                              <div class=\"layui-form\" style=\"margin-left: 10px;\">\r\n                                <input type=\"radio\" name=\"kbd-key-layer\" value=\"0\" title=\"默认\" data-i18n-title=\"STRID_SETTING_DEFAULT\" lay-filter=\"kbd-key-layer\">\r\n                                <input type=\"radio\" name=\"kbd-key-layer\" value=\"1\" title=\"Fn层\" data-i18n-title=\"STRID_KBD_KEY_FN_LAYER\" lay-filter=\"kbd-key-layer\"> \r\n                              </div>\r\n                            </td>\r\n                          </tr>\r\n                        </table>\r\n                      </div>\r\n\r\n                      <div id=\"kbd-key-desc-container\" style=\"text-align: center; width: 300px; height: 200px; margin-top: 96px; border: 1px solid gray; \">\r\n                        <table style=\"align-items: center;\">\r\n                          <tr>\r\n                            <td style=\"width:300px;height: 50px;align-items: center;justify-content: center;\">\r\n                              <p id=\"kbd-key-desc-title\" class=\"layui-setting-title\" style=\"color: gray;\" data-i18n-text=\"STRID_KBD_CURRENT_KEY_FUNCTION\">当前按键功能</p>\r\n                            </td>\r\n                          </tr>\r\n                          <tr>\r\n                            <td style=\"width:300px;height: 1px;align-items: center;justify-content: center;\">\r\n                              <div id=\"kbd-key-desc-line\" style=\"width: 300px; height: 1px; background-color: gray;\">\r\n                            </td>\r\n                          </tr>\r\n                          <tr>\r\n                            <td style=\"display: flex; width:300px;height: 95px;align-items: center;justify-content: center;\">\r\n                              <p id=\"kbd-key-desc1\" style=\"font-size: medium;color: gray\" data-i18n-text=\"STRID_KBD_NO_KEY_SELECTED\">未选择按键</p>\r\n                              <p id=\"kbd-key-desc-arrow\" style=\"display: none; margin-left: 20px; margin-right: 20px; font: bold; font-size: large;color: gray\"> → </p>\r\n                              <p id=\"kbd-key-desc2\" style=\"display: none; font-size: medium;color: #16B777\" > </p>\r\n                            </td>\r\n                          </tr>\r\n                          <tr>\r\n                            <td style=\"width:300px;height: 50px;align-items: center;justify-content: center;display: flex;\">\r\n                              <button id=\"kbd-key-default\" class=\"layui-btn layui-key-desc-button\" kbd-key-default-action=\"select\" disabled=\"disabled\" data-i18n-text=\"STRID_KBD_DEFAULT_SETTING\">恢复默认</button>\r\n                              <button id=\"kbd-key-set\" class=\"layui-btn layui-key-desc-button\" style=\"margin-left: 90px;\" kbd-key-set-action=\"select\" disabled=\"disabled\" data-i18n-text=\"STRING_OK\">确定</button>\r\n                            </td>\r\n                          </tr>\r\n                        </table>\r\n                      </div>\r\n                    </div> \r\n                  </div>\r\n                </td>\r\n              </tr>\r\n\r\n              <tr>\r\n                <td style=\"width: 100%;align-content: center;\">\r\n                  <div id=\"tab-kbd-setting-key-type\" class=\"layui-tab layui-tab-brief\" lay-filter=\"kbd-setting-key-type\">\r\n                    <ul id=\"kbd-key-type-list\" class=\"layui-tab-title\"  style=\"width: auto;\">\r\n                      <li lay-id=\"0\" data-i18n-text=\"STRID_KBD_AND_MOUSE\">键盘鼠标</li>\r\n                      <li lay-id=\"1\" data-i18n-text=\"STRID_KBD_FUNCTION_KEY\">功能按键</li>\r\n                      <li lay-id=\"2\" data-i18n-text=\"STRID_SETTING_MAPPING_TYPE_MACRO\">宏</li>\r\n                    </ul>\r\n                    <div class=\"layui-tab-content\">\r\n                      <div class=\"layui-tab-item\">\r\n                        <div id=\"kbd-setting-key-base-container\" style=\"width: auto;\">\r\n                          <div id=\"select-key-container\" style=\"width: 100%;height: 280px; margin-left: 20px;\">\r\n                          </div>\r\n                          <div class=\"layui-setting-title-container\" style=\"margin-left: 20px;\">\r\n                            <div class=\"layui-setting-title-bar\" style=\"margin-right: 4px;\"></div>\r\n                            <p data-i18n-text=\"STRID_KBD_MOUSE_KEY\">鼠标按键</p>\r\n                          </div>\r\n                          <div id=\"mouse-select-key-container\" style=\"width: 100%;height: 40px; margin-left: 20px; margin-bottom: 10px;\">\r\n                          </div>\r\n                        </div>\r\n                      </div>\r\n                      <div class=\"layui-tab-item\">\r\n                        <div id=\"kbd-setting-function-container\" style=\"display: none; width: auto;\" >\r\n                          <div style=\"margin-left: 10px;\">\r\n                            <div class=\"layui-setting-title-container\">\r\n                              <div class=\"layui-setting-title-bar\" style=\"margin-right: 4px;\"></div>\r\n                              <p data-i18n-text=\"STRID_KBD_KEY_RGB_CONTROL\">灯效控制</p>\r\n                            </div>\r\n                            <div id=\"kbd-key-rgb-container\" style=\"width: 100%;height: 40px; margin-bottom: 10px;\"></div>\r\n                            \r\n                            <div class=\"layui-setting-title-container\" style=\"margin-top:20px;\">\r\n                              <div class=\"layui-setting-title-bar\" style=\"margin-right: 4px;\"></div>\r\n                              <p data-i18n-text=\"STRID_KBD_KEY_MEDIA_CONTROL\">媒体控制</p>\r\n                            </div>\r\n                            <div id=\"kbd-key-media-container\" style=\"width: 100%;height: 40px; margin-bottom: 10px;\"></div>\r\n\r\n                             <div class=\"layui-setting-title-container\" style=\"margin-top:20px;\">\r\n                              <div class=\"layui-setting-title-bar\" style=\"margin-right: 4px;\"></div>\r\n                              <p data-i18n-text=\"STRID_KBD_KEY_WINDOWS\">Windows系统功能</p>\r\n                            </div>\r\n                            <div id=\"kbd-key-windows-container\" style=\"width: 100%;height: 40px; margin-bottom: 10px;\"></div>\r\n                          </div>\r\n                          <div style=\"margin-left: 50px;\">\r\n                            <div class=\"layui-setting-title-container\">\r\n                              <div class=\"layui-setting-title-bar\" style=\"margin-right: 4px;\"></div>\r\n                              <p data-i18n-text=\"STRID_KBD_OTHER\">其他</p>\r\n                            </div>\r\n                            <div style=\"margin-top: 10px;\">\r\n                              <button id=\"kbd-key-switch-wasd\" class=\"layui-btn layui-hover-bg\" style=\"height: 37px; \"kbd-key-switch-wasd-action=\"select\" data-i18n-text=\"STRID_KBD_SWITCH_WASD\">交换WASD</button>\r\n                              <p style=\"margin-top: 10px;color: gray;\" data-i18n-text=\"STRID_KBD_SWITCH_WASD_HINT\">交换WASD和上下左右，长按3秒有效。</p>\r\n                            </div>\r\n                            <div style=\"margin-top: 20px;\">\r\n                              <button id=\"kbd-key-switch-mac-mode\" class=\"layui-btn layui-hover-bg\" style=\"height: 37px; \"kbd-key-switch-mac-mode-action=\"select\" data-i18n-text=\"STRID_KBD_SWITCH_MAC_MODE\">切换Mac模式</button>\r\n                              <p style=\"margin-top: 10px;color: gray;\" data-i18n-text=\"STRID_KBD_SWITCH_MAC_MODE_HINT\">开启Mac模式，交换Win和Alt。</p>\r\n                            </div>\r\n                          </div>\r\n                        </div>\r\n                      </div>\r\n                      <div class=\"layui-tab-item\">\r\n                        <div id=\"kbd-setting-macro-container\" style=\"display: none; width: auto;\" >\r\n                          <div style=\"width: auto; margin-left: 10px; display: flex;\">\r\n                            <div style=\"width: auto;\">\r\n                              <div class=\"layui-setting-title-container\">\r\n                                <div class=\"layui-setting-title-bar\" style=\"margin-right: 2px;\"></div>\r\n                                <p class=\"layui-setting-title\" data-i18n-text=\"STRID_KBD_MACRO_LIST\" style=\"width: 100%;\">宏列表</p>\r\n                              </div>\r\n                              <div class=\"layui-sub-setting-section\" style=\"width: 440px; height: 300px; margin-top: 10px;\">\r\n                                <div id=\"kbd-macro-container\">\r\n                                </div>\r\n                              </div>\r\n                            </div>\r\n                            <div style=\"width: auto; margin-left: 30px\">\r\n                              <div class=\"layui-setting-title-container\">\r\n                                <div class=\"layui-setting-title-bar\" style=\"margin-right: 2px;\"></div>\r\n                                <p class=\"layui-setting-title\" data-i18n-text=\"STRID_KBD_MACRO_ACTION\" style=\"width: 100%;\">宏动作</p>\r\n                              </div>\r\n                              <div class=\"layui-sub-setting-section\" class=\"layui-form\" style=\"width: 800px; height: 300px; margin-top: 10px;\">\r\n                                <div id=\"setting-mapping-kbd-macro-edit-panel\" class=\"layui-form\" style=\"width: 100%; height: 240px; margin-top: 5px;  overflow:scroll;overflow-x:hidden;\">\r\n                                  <div id=\"kbd-macro-edit-container\">\r\n                                  </div>\r\n                                </div>\r\n                                <div style=\"width: 100%; margin-left: 200px; margin-top: 10px;display: flex;\">\r\n                                  <button id=\"kbd-macro-record\" class=\"layui-btn layui-gray-button\" style=\"width: 80px;\" data-i18n-text=\"STRID_SETTING_MAPPING_MACRO_RECORD\" kbd-macro-record-action=\"select\">录制</button>\r\n                                  <button id=\"kbd-macro-add\" class=\"layui-btn layui-gray-button\" style=\"width: 80px; margin-left: 20px;\" kbd-macro-add-action=\"select\" data-i18n-text=\"STRID_SETTING_MAPPING_MACRO_ACTION_ADD_S\">添加</button>\r\n                                  <button id=\"kbd-macro-clear\" class=\"layui-btn layui-gray-button\" style=\"width: 80px; margin-left: 20px;\" kbd-macro-clear-action=\"select\" data-i18n-text=\"STRID_CLEAR\">清除</button>\r\n                                  <button id=\"kbd-macro-save\" class=\"layui-btn layui-gray-button\" style=\"width: 80px; margin-left: 20px;\" kbd-macro-save-action=\"select\" data-i18n-text=\"STRID_SAVE\">保存</button>\r\n                                </div> \r\n                              </div>\r\n                            </div>\r\n                          </div>\r\n                        </div>\r\n                      </div>\r\n                      <div class=\"layui-tab-item layui-show\">\r\n                      </div>\r\n                    </div>\r\n                  </div>\r\n                </td>\r\n              </tr>\r\n            </table>\r\n          </div>\r\n        </div>\r\n        <div class=\"layui-tab-item\">\r\n          <div id=\"kbd-main-setting-light-container\" class=\"key-shortcuts-table\" style=\"display: none;\" >\r\n            <table style=\"width: 100%; margin-bottom: 30px;\">\r\n              <tr>\r\n                <td style=\"width: 100%;min-width: 640px;\">\r\n                  <div style=\"display: flex;\" >\r\n                    <div style=\"margin-left: 40px;\">\r\n                      <div id=\"kbd-mapping-light-container\" style=\"text-align: center;width: 934px;height: 348px;\">\r\n                      </div>\r\n                    </div>\r\n\r\n                    <div style=\"width: 80px; margin-left: 20px; margin-right: 10px;\">\r\n                      <button id=\"kbd-light-wasd\" class=\"layui-btn layui-gray-button\" style=\"width: 80px; margin-left: 10px;margin-top: 30px;\" value=\"WASD\" kbd-light-action=\"select\">WASD</button>\r\n                      <button id=\"kbd-light-select-all\" class=\"layui-btn layui-gray-button\" style=\"width: 80px; margin-top: 20px;\" value=\"ALL\" kbd-light-action=\"select\" data-i18n-text=\"STRID_KBD_SELECT_ALL\">全选</button>\r\n                      <button id=\"kbd-light-reverse-all\" class=\"layui-btn layui-gray-button\" style=\"width: 80px; margin-top: 20px;\" value=\"REVERSE\" kbd-light-action=\"select\" data-i18n-text=\"STRID_KBD_REVERSE_ALL\">反选</button>\r\n                      <button id=\"kbd-light-clear\" class=\"layui-btn layui-gray-button\" style=\"width: 80px; margin-top: 20px;\" value=\"CLEAR\" kbd-light-action=\"select\" data-i18n-text=\"STRID_CLEAR\">清除</button>\r\n                    </div> \r\n                  </div>\r\n                </td>\r\n              </tr>\r\n\r\n              <tr>\r\n                <td style=\"width: 100%;align-content: center;\">\r\n                  <div id=\"tab-kbd-setting-light-type\" class=\"layui-tab layui-tab-brief\" lay-filter=\"kbd-setting-light-type\">\r\n                    <ul id=\"kbd-light-type-list\" class=\"layui-tab-title\"  style=\"width: auto;\">\r\n                      <li lay-id=\"0\" data-i18n-text=\"STRID_KBD_LIGHT_KEY\">按键灯效</li>\r\n                      <li lay-id=\"1\" data-i18n-text=\"STRID_KBD_LIGHT_BOX\">底部灯效</li>\r\n                    </ul>\r\n                    <div class=\"layui-tab-content\">\r\n                      <div class=\"layui-tab-item\">\r\n                        <div id=\"kbd-setting-light-container\" style=\"width: 1020px; margin-top: 20px;\">\r\n                          <div style=\"display: flex; margin-left: 40px; margin-bottom: 10px;\">\r\n                            <div style=\"width: 425px;\">\r\n                              <div style=\"width: 100%;\">\r\n                                <div class=\"layui-setting-title-container\">\r\n                                  <div class=\"layui-setting-title-bar\" style=\"margin-right: 2px;\"></div>\r\n                                  <p class=\"layui-setting-title\" data-i18n-text=\"STRID_KBD_LIGHT_MODE\">灯效模式</p>\r\n                                </div>\r\n                                <div class=\"layui-form\" id=\"language-form\" style=\"margin-top: 10px;\">\r\n                                  <div id=\"kbd-light-mode-container\" class=\"layui-input-inline\" style=\"width: 150px; height: 40px;\"></div>\r\n                                </div>\r\n                                <div style=\"margin-top: 20px;\">\r\n                                  <p style=\"color: gray;\" data-i18n-text=\"STRID_KBD_LIGHT_MODE_HINT\">自定义模式可以编辑每个按键灯颜色。</p>\r\n                                </div>\r\n                              </div>\r\n                              <div style=\"width: 100%; margin-top: 20px;\">\r\n                                <div class=\"layui-setting-title-container\">\r\n                                  <div class=\"layui-setting-title-bar\" style=\"margin-right: 2px;\"></div>\r\n                                  <p class=\"layui-setting-title\" data-i18n-text=\"STRID_SETTING_SLEEP_TIME\">休眠时间</p>\r\n                                </div>\r\n                                <div class=\"layui-form\" id=\"language-form\" style=\"margin-top: 10px;\">\r\n                                  <div id=\"kbd-light-sleep-time-container\" class=\"layui-input-inline\" style=\"width: 150px; height: 40px;\"></div>\r\n                                </div>\r\n                                <div style=\"margin-top: 20px;\">\r\n                                  <p style=\"color: gray;\" data-i18n-text=\"STRID_SETTING_SLEEP_TIME_TIPS\">鼠标静置该时间后，进入休眠状态，以降低功耗。</p>\r\n                                </div>\r\n                              </div>\r\n                            </div>\r\n\r\n                            <div style=\"width:440px; margin-left: 55px;\">\r\n                              <div class=\"layui-setting-title-container\" style=\"height:40px\">\r\n                                <div class=\"layui-setting-title-bar\"style=\"margin-right: 2px;\"></div>\r\n                                <p class=\"layui-setting-title\" data-i18n-text=\"STRID_KBD_LIGHT_PARAM_SETTING\" style=\"width:280px;\">参数设置</p>\r\n                                <div id=\"kbd-light-button-container\" style=\"display: none; margin-left: 10px;\">\r\n                                  <button id=\"kbd-light-cancel\" class=\"layui-btn layui-gray-button\"  kbd-light-cancel-action=\"select\" data-i18n-text=\"STRING_CANCEL\">取消</button>\r\n                                  <button id=\"kbd-light-save\" class=\"layui-btn layui-bg-blue\" style=\"margin-left: 20px\" kbd-light-save-action=\"select\" data-i18n-text=\"STRID_SAVE\">保存</button>\r\n                                </div>\r\n                              </div>\r\n\r\n                              <div class=\"layui-sub-setting-section\" style=\"width: 440px; margin-top: 10px;\">\r\n                                <div style=\"display: flex; align-items: center\" >\r\n                                  <p data-i18n-text=\"STRID_KBD_LIGHT_COLOR_SELECT \">灯效颜色设置</p>\r\n                                  <input id=\"pick-color\" name=\"pick-color\" type=\"color\" style=\"background-color: #202020; border: 1px solid gray; margin-left: 10px; cursor: pointer;\" value=\"#0000FF\" onchange=\"changeColor()\">  \r\n                                </div>\r\n                                <div style=\"display: flex; text-align: center; align-items: center;margin-top: 10px;\" >\r\n                                  <p style=\"width: 60px;\">R</p>\r\n                                  <p style=\"width: 60px; margin-left: 40px;\">G</p>\r\n                                  <p style=\"width: 60px;margin-left: 40px;\">B</p> \r\n                                </div>\r\n                                <div style=\"display: flex; align-items: center; margin-top: 4px;\" >\r\n                                  <input id=\"color-r-input\" class=\"layui-input\" type=\"number\" lay-affix=\"number\" lay-filter=\"color-r-input\" style=\"width: 80px; margin: 0 auto; display: block;\" placeholder=\"\" step=\"1\" min=\"0\" max=\"255\">\r\n                                  <input id=\"color-g-input\" class=\"layui-input\" type=\"number\" lay-affix=\"number\" lay-filter=\"color-g-input\" style=\"width: 80px; margin-left: 20px; display: block;\" placeholder=\"\" step=\"1\" min=\"0\" max=\"255\">\r\n                                  <input id=\"color-b-input\" class=\"layui-input\" type=\"number\" lay-affix=\"number\" lay-filter=\"color-b-input\" style=\"width: 80px; margin-left: 20px; display: block;\" placeholder=\"\" step=\"1\" min=\"0\" max=\"255\"> \r\n                                </div>\r\n\r\n                                <div id=\"kbd-light-global-brightness-container\" style=\"margin-top: 20px;\">\r\n                                  <p data-i18n-text=\"STRID_KBD_LIGHT_GLOBAL_BRIGHTNESS\">全局亮度</p>\r\n                                  <div style=\"display: flex; margin-left: 8px;margin-top: 20px;\">\r\n                                    <div id=\"kbd-light-global-brightness\" style=\"width: 400px;height: 40px; \"></div>\r\n                                    <p style=\"margin-left:10px; margin-top: -6px;\">%</p>\r\n                                  </div>\r\n                                </div>\r\n\r\n                                <div id=\"kbd-light-global-speed-container\" >\r\n                                  <p data-i18n-text=\"STRID_KBD_LIGHT_GLOBAL_SPEED\">全局速度</p>\r\n                                  <div style=\"disp