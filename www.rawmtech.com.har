            "text": "layui.define([\"i18n\"], function (exports) {\r\n    var i18n = layui.i18n;\r\n    var i18np = {};\r\n    i18np.loadProperties = function (resource_url) {\r\n        var langName = layui.data('lang').name;\r\n        if (langName == \"undefined\" || langName == \"\" || langName == null) {\r\n            if (navigator.userLanguage)\r\n                langName = navigator.userLanguage;\r\n            else\r\n                langName = navigator.language;\r\n            langName = langName.replace(/-/,\"_\");\r\n        }\r\n        if (langName == 'zh') {\r\n            langName = 'zh_CN';\r\n        }\r\n        if (langName != 'zh_CN' && langName != 'en_US' && langName != 'zh_TW' && langName != 'ko_KR' && langName != 'ja_JP' && langName != 'uk_UA') {\r\n            langName = 'en_US';\r\n        }\r\n        i18n.properties({\r\n            name: 'i18n',\r\n            path: resource_url + 'i18n/bundle',\r\n            mode: \"map\",\r\n            language: langName,\r\n            cache: false,\r\n            encoding: 'UTF-8',\r\n            callback: function () {\r\n                try {\r\n                    $('[data-i18n-placeholder]').each(function () {\r\n                        try {\r\n                            $(this).attr('placeholder', i18n.prop($(this).attr('data-i18n-placeholder')));\r\n                        } catch (ex) { }\r\n                    });\r\n                    $('[data-i18n-title]').each(function () {\r\n                        try {\r\n                            $(this).attr('title', i18n.prop($(this).attr('data-i18n-title')));\r\n                        } catch (ex) { }\r\n                    });\r\n                    $('[data-i18n-text]').each(function () {\r\n                        try {\r\n                            var html = $(this).html();\r\n                            var reg = /<(.*)>/;\r\n                            if (reg.test(html)) {\r\n                                var htmlValue = reg.exec(html)[0];\r\n                                $(this).html(htmlValue + i18n.prop($(this).attr('data-i18n-text')));\r\n                            }\r\n                            else {\r\n                                $(this).text(i18n.prop($(this).attr('data-i18n-text')));\r\n                            }\r\n                            if ($(this) instanceof Option) {\r\n                                layui.form.render('select');\r\n                            }\r\n                        } catch (ex) { }\r\n                    });\r\n                    $('[data-i18n-value]').each(function () {\r\n                        try {\r\n                            $(this).val(i18n.prop($(this).attr('data-i18n-value')));\r\n                        } catch (ex) { }\r\n                    });\r\n                }\r\n                catch (ex) { }\r\n            },\r\n        });\r\n    };\r\n    i18np.prop = function (i18nKey) {\r\n        try {\r\n            return i18n.prop(i18nKey);\r\n        } catch (ex) {\r\n            return i18nKey;\r\n        }\r\n    };\r\n    exports(\"i18np\", i18np);\r\n});"
