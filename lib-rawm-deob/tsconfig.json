{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "strictPropertyInitialization": false,
    "esModuleInterop": true,
    "noEmit": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": [
    "src/**/*.ts",
    "data/**/*.ts",
    "state/**/*.ts",
    "protocol/**/*.ts",
    "lib/**/*.ts",
    "ui/**/*.ts",
    "scripts/**/*.mjs"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
